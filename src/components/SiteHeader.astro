---
import {
  headerWordSolvers,
  headerWordLists,
  headerDailyGameHints,
  headerDailyGameHintsMoreHref,
  headerCrosswords,
} from '../lib/nav-links';

const rawPath = Astro.url.pathname;
const currentPath = rawPath.replace(/\/$/, '') || '/';
const wordsByLengthLinks = [10, 9, 8, 7, 6, 5, 4, 3, 2].map((n) => ({
  name: `${n}-Letter Words`,
  href: `/${n}-letter-words`,
}));

function isActive(href: string): boolean {
  if (!href || href === '#') return false;
  const h = href.replace(/\/$/, '') || '/';
  return currentPath === h || currentPath.startsWith(h + '/');
}
---

<header class="wt-top-header">
  <div class="wt-top-header-inner">
    <div class="wt-bar-left">
      <!-- Mobile: hamburger first (reference layout) -->
      <button
        type="button"
        class="wt-bar-btn wt-bar-hamburger"
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <a href="/" class="wt-bar-logo" aria-label="WordTips Home">
        <span class="wt-bar-logo-mark" aria-hidden="true">W</span>
        <span class="wt-bar-logo-text">ord<span class="wt-bar-logo-tips">tips</span></span>
      </a>
    </div>

    <nav class="wt-bar-nav" aria-label="Main navigation">
      <!-- Word Solvers -->
      <div class="wt-dd">
        <button type="button" class="wt-dd-trigger" aria-expanded="false" aria-haspopup="true" id="dd-word-solvers">
          Word Solvers
          <svg class="wt-dd-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="wt-dd-panel wt-dd-panel--simple" role="menu" aria-labelledby="dd-word-solvers">
          <div class="wt-dd-caret" aria-hidden="true"></div>
          <div class="wt-dd-body">
            {headerWordSolvers.map((link) => (
              <a
                href={link.href}
                class:list={['wt-dd-link', { 'wt-dd-link--active': isActive(link.href) }]}
                role="menuitem"
              >
                <span>{link.name}</span>
                {isActive(link.href) && (
                  <svg class="wt-dd-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Word Lists -->
      <div class="wt-dd">
        <button type="button" class="wt-dd-trigger" aria-expanded="false" aria-haspopup="true" id="dd-word-lists">
          Word Lists
          <svg class="wt-dd-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="wt-dd-panel wt-dd-panel--hints" role="menu" aria-labelledby="dd-word-lists">
          <div class="wt-dd-caret" aria-hidden="true"></div>
          <div class="wt-dd-body wt-dd-body--hints">
            {headerWordLists.map((link) => (
              <a href={link.href} class:list={['wt-dd-link', { 'wt-dd-link--active': isActive(link.href) }]} role="menuitem">
                <span>{link.name}</span>
                {isActive(link.href) && (
                  <svg class="wt-dd-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                )}
              </a>
            ))}
            <div class="wt-length-block" role="group" aria-label="Words by Length">
              <div class="wt-length-title">Words by Length</div>
              <div class="wt-length-list">
                {wordsByLengthLinks.map((item) => (
                  <a href={item.href} class="wt-length-link" role="menuitem">{item.name}</a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Daily Game Hints -->
      <div class="wt-dd wt-dd--wide">
        <button type="button" class="wt-dd-trigger" aria-expanded="false" aria-haspopup="true" id="dd-daily">
          Daily Game Hints
          <svg class="wt-dd-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="wt-dd-panel wt-dd-panel--hints" role="menu" aria-labelledby="dd-daily">
          <div class="wt-dd-caret" aria-hidden="true"></div>
          <div class="wt-dd-body wt-dd-body--hints">
            {headerDailyGameHints.map((hint) => (
              <a href={hint.href} class:list={['wt-hint-row', { 'wt-hint-row--active': isActive(hint.href) }]} role="menuitem">
                <span class="wt-hint-ico" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                </span>
                <span class="wt-hint-text">
                  <span class="wt-hint-title">{hint.name}</span>
                  <span class="wt-hint-sub">{hint.subtitle}</span>
                </span>
              </a>
            ))}
            <a href={headerDailyGameHintsMoreHref} class="wt-hint-more" role="menuitem">View More</a>
          </div>
        </div>
      </div>

      <!-- Crosswords -->
      <div class="wt-dd">
        <button type="button" class="wt-dd-trigger" aria-expanded="false" aria-haspopup="true" id="dd-crosswords">
          Crosswords
          <svg class="wt-dd-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="wt-dd-panel wt-dd-panel--simple" role="menu" aria-labelledby="dd-crosswords">
          <div class="wt-dd-caret" aria-hidden="true"></div>
          <div class="wt-dd-body">
            {headerCrosswords.map((link) => (
              <a href={link.href} class:list={['wt-dd-link', { 'wt-dd-link--active': isActive(link.href) }]} role="menuitem">
                <span>{link.name}</span>
                {isActive(link.href) && (
                  <svg class="wt-dd-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>

    <div class="wt-bar-actions">
      <a href="/contact" class="wt-mobile-app-pill" aria-label="Contact" title="Contact">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><path d="M12 18h.01"/></svg>
      </a>
      <button type="button" class="wt-bar-btn" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle theme">
        <span id="icon-sun" class="hidden" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        </span>
        <span id="icon-moon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile drawer -->
<div class="wt-mobile-drawer" id="mobile-drawer" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="wt-mobile-head">
    <span class="wt-bar-logo-text wt-mobile-brand"><span class="wt-bar-logo-mark">W</span>ord<span class="wt-bar-logo-tips">tips</span></span>
    <button type="button" class="wt-bar-btn" id="mobile-close-btn" aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="wt-mobile-scroll">
    <div class="wt-mobile-section">Word Solvers</div>
    {headerWordSolvers.map((link) => (
      <a href={link.href} class="wt-mobile-a" data-close-drawer>{link.name}</a>
    ))}
    <div class="wt-mobile-section">Word Lists</div>
    {headerWordLists.map((link) => (
      <a href={link.href} class="wt-mobile-a" data-close-drawer>{link.name}</a>
    ))}
    <div class="wt-mobile-section">Daily Game Hints</div>
    {headerDailyGameHints.map((hint) => (
      <a href={hint.href} class="wt-mobile-a wt-mobile-hint" data-close-drawer>
        <span class="wt-mobile-hint-title">{hint.name}</span>
        <span class="wt-mobile-hint-sub">{hint.subtitle}</span>
      </a>
    ))}
    <a href={headerDailyGameHintsMoreHref} class="wt-mobile-a wt-mobile-more" data-close-drawer>View More</a>
    <div class="wt-mobile-section">Crosswords</div>
    {headerCrosswords.map((link) => (
      <a href={link.href} class="wt-mobile-a" data-close-drawer>{link.name}</a>
    ))}
    <div class="wt-mobile-section">Info</div>
    <a href="/about" class="wt-mobile-a" data-close-drawer>About</a>
    <a href="/contact" class="wt-mobile-a" data-close-drawer>Contact</a>
  </div>
</div>
<div class="wt-mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

<script>
  (function () {
    var themeKey = 'wordtips-theme-v2';
    var root = document.documentElement;
    function applyTheme(dark) {
      root.classList.toggle('dark', dark);
      var sun = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      if (sun) sun.classList.toggle('hidden', !dark);
      if (moon) moon.classList.toggle('hidden', dark);
      try { localStorage.setItem(themeKey, dark ? 'dark' : 'light'); } catch {}
    }
    var stored = localStorage.getItem(themeKey);
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    applyTheme(stored === 'dark' || (!stored && prefersDark));
    var tt = document.getElementById('theme-toggle');
    if (tt) tt.addEventListener('click', function () {
      applyTheme(!root.classList.contains('dark'));
    });

    var mq = window.matchMedia('(min-width: 901px)');
    function closeAllDd() {
      document.querySelectorAll('.wt-dd-trigger').forEach(function (b) {
        b.setAttribute('aria-expanded', 'false');
      });
    }
    document.querySelectorAll('.wt-dd').forEach(function (dd) {
      var btn = dd.querySelector('.wt-dd-trigger');
      var panel = dd.querySelector('.wt-dd-panel');
      if (!btn || !panel) return;
      btn.addEventListener('click', function (e) {
        if (mq.matches) return;
        e.preventDefault();
        e.stopPropagation();
        var open = btn.getAttribute('aria-expanded') === 'true';
        closeAllDd();
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
    });
    document.addEventListener('click', function () { closeAllDd(); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeAllDd();
    });

    var drawer = document.getElementById('mobile-drawer');
    var overlay = document.getElementById('mobile-overlay');
    var openBtn = document.getElementById('mobile-menu-btn');
    var closeBtn = document.getElementById('mobile-close-btn');
    function openDrawer() {
      drawer.classList.add('is-open');
      overlay.classList.add('is-open');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer.classList.remove('is-open');
      overlay.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    if (openBtn) openBtn.addEventListener('click', function (e) { e.stopPropagation(); openDrawer(); });
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (overlay) overlay.addEventListener('click', closeDrawer);
    if (drawer) drawer.querySelectorAll('[data-close-drawer]').forEach(function (el) {
      el.addEventListener('click', closeDrawer);
    });
  })();
</script>

<style>
  .wt-top-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bar-bg);
    color: #fff;
    width: 100%;
    box-shadow: 0 1px 0 rgb(0 0 0 / 0.08);
  }
  .wt-top-header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 0.75rem 0 0.5rem;
    min-height: 3.25rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 0.25rem;
  }
  .wt-bar-left {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    min-width: 0;
  }

  .wt-bar-hamburger {
    display: none;
    color: #fff;
  }
  .wt-bar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: none;
    border-radius: 0.5rem;
    background: transparent;
    color: #fff;
    cursor: pointer;
    flex-shrink: 0;
  }
  .wt-bar-btn:hover { background: rgb(255 255 255 / 0.12); }

  .wt-bar-logo {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    color: #fff;
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.02em;
    margin-right: 0.75rem;
    flex-shrink: 0;
  }
  .wt-bar-logo-mark {
    position: relative;
    display: inline-block;
    color: #fff;
    font-weight: 900;
  }
  .wt-bar-logo-mark::after {
    content: '';
    position: absolute;
    top: 0.05em;
    right: -0.15em;
    width: 0.38em;
    height: 0.38em;
    background: #fbbf24;
    border-radius: 50%;
    box-shadow: 0 0 0 1px rgb(0 0 0 / 0.15);
  }
  .wt-bar-logo-tips { font-weight: 800; opacity: 0.95; }

  .wt-bar-nav {
    display: flex;
    align-items: stretch;
    gap: 0.125rem;
    justify-self: center;
    min-width: 0;
  }

  .wt-dd {
    position: relative;
  }
  .wt-dd-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.65rem;
    border: none;
    border-radius: 0.5rem;
    background: transparent;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
  }
  .wt-dd-trigger:hover,
  .wt-dd:focus-within > .wt-dd-trigger { background: rgb(255 255 255 / 0.12); }
  .wt-dd-chevron {
    flex-shrink: 0;
    opacity: 0.9;
    transition: transform 0.2s ease;
  }
  .wt-dd:hover .wt-dd-trigger .wt-dd-chevron,
  .wt-dd:focus-within .wt-dd-trigger .wt-dd-chevron,
  .wt-dd-trigger[aria-expanded="true"] .wt-dd-chevron {
    transform: rotate(180deg);
  }

  .wt-dd-panel {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(0.35rem);
    min-width: 15rem;
    background: #fff;
    color: #0f172a;
    border-radius: 0.65rem;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.18);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s, visibility 0.15s, transform 0.15s;
    z-index: 300;
    padding-top: 0.35rem;
  }
  .wt-dd--wide .wt-dd-panel {
    min-width: 17.5rem;
  }
  .wt-dd-caret {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -100%);
    width: 0;
    height: 0;
    border-left: 9px solid transparent;
    border-right: 9px solid transparent;
    border-bottom: 8px solid #fff;
    filter: drop-shadow(0 -1px 0 rgb(0 0 0 / 0.04));
  }
  .wt-dd-body {
    padding: 0.35rem 0.5rem 0.5rem;
    border-radius: 0.65rem;
  }
  .wt-dd-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    border-radius: 0.45rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #0f172a;
    text-decoration: none;
  }
  .wt-dd-link:hover { background: #f1f5f9; }
  .wt-dd-link--active {
    background: #dcfce7;
    color: #14532d;
    font-weight: 600;
  }
  .wt-dd-check { flex-shrink: 0; color: #14532d; }

  .wt-hint-row {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 0.6rem;
    border-radius: 0.45rem;
    text-decoration: none;
    color: inherit;
  }
  .wt-hint-row:hover { background: #f8fafc; }
  .wt-hint-row--active { background: #ecfdf5; }
  .wt-hint-ico {
    flex-shrink: 0;
    width: 2.25rem;
    height: 2.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: #e0f2f1;
    color: #0f766e;
  }
  .wt-hint-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
  }
  .wt-hint-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: #0f172a;
  }
  .wt-hint-sub {
    font-size: 0.75rem;
    color: #64748b;
  }
  .wt-hint-more {
    display: block;
    padding: 0.65rem 0.6rem 0.35rem;
    margin-top: 0.25rem;
    border-top: 1px solid #e2e8f0;
    font-size: 0.875rem;
    font-weight: 700;
    color: #0f766e;
    text-decoration: none;
  }
  .wt-hint-more:hover { text-decoration: underline; }

  .wt-length-block {
    margin-top: 0.55rem;
    padding-top: 0.7rem;
    border-top: 1px solid #e2e8f0;
  }
  .wt-length-title {
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #5f6b7a;
    margin: 0 0 0.5rem;
    padding: 0 0.15rem;
  }
  .wt-length-list {
    display: grid;
    gap: 0.35rem;
  }
  .wt-length-link {
    display: block;
    text-align: center;
    padding: 0.55rem 0.6rem;
    border-radius: 0.5rem;
    background: #f2f4f5;
    border-right: 5px solid #79AE6F;
    color: #0f172a;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.98rem;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .wt-length-link:hover {
    background: #edf4eb;
    border-right-color: #346739;
    transform: translateX(1px);
  }

  @media (min-width: 901px) {
    .wt-dd:hover .wt-dd-panel,
    .wt-dd:focus-within .wt-dd-panel {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0.2rem);
    }
  }

  .wt-bar-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    justify-self: end;
    flex-shrink: 0;
  }
  .wt-mobile-app-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    border: 2px solid rgb(255 255 255 / 0.55);
    color: #fff;
    text-decoration: none;
  }
  .wt-mobile-app-pill:hover { background: rgb(255 255 255 / 0.12); }

  .hidden { display: none !important; }

  @media (max-width: 900px) {
    .wt-top-header-inner {
      display: flex;
    }
    .wt-bar-hamburger { display: inline-flex; }
    .wt-bar-nav { display: none; }
    .wt-bar-left { flex: 1; }
    .wt-bar-logo { margin-right: auto; }
  }

  .wt-mobile-drawer {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(20rem, 92vw);
    background: var(--card, #fff);
    color: var(--foreground, #0f172a);
    z-index: 400;
    transform: translateX(-100%);
    transition: transform 0.25s ease;
    overflow-y: auto;
    border-right: 1px solid var(--border, #e2e8f0);
  }
  .wt-mobile-drawer.is-open { transform: translateX(0); }
  .wt-mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgb(0 0 0 / 0.45);
    z-index: 399;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s;
  }
  .wt-mobile-overlay.is-open { opacity: 1; visibility: visible; }
  .wt-mobile-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border, #e2e8f0);
 background: var(--nav-bar-bg);
    color: #fff;
  }
  .wt-mobile-brand { color: #fff; }
  .wt-mobile-brand .wt-bar-logo-mark::after { background: #fbbf24; }
  .wt-mobile-scroll { padding: 0.75rem; }
  .wt-mobile-section {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-foreground, #64748b);
    margin: 0.75rem 0 0.35rem;
  }
  .wt-mobile-section:first-child { margin-top: 0; }
  .wt-mobile-a {
    display: block;
