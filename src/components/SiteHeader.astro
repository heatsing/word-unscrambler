---
const currentPath = Astro.url.pathname;

// word.tips exact nav structure
const mainNavLinks = [
  { name: 'Words With Friends', href: '/words-with-friends' },
  { name: 'Wordle', href: '/wordle' },
  { name: 'Scrabble', href: '/scrabble' },
  { name: 'Word Cookies', href: '/word-cookies' },
  { name: 'Boggle', href: '/boggle-solver' },
  { name: 'Wordle Solver', href: '/wordle-solver' },
];

const moreLinks = [
  { name: 'Words With Friends Cheat', href: '/words-with-friends' },
  { name: 'Anagram Solver', href: '/anagram-solver' },
  { name: 'Word Unscrambler', href: '/word-unscrambler' },
  { name: 'Crossword Solver', href: '/crossword-solver' },
  { name: 'Text Twist', href: '/text-twist' },
  { name: 'Jumble Solver', href: '/jumble-solver' },
  { name: 'Word Generator', href: '/word-generator' },
  { name: 'Letter Boxed', href: '/letter-boxed-solver' },
  { name: 'Wordscapes', href: '/wordscapes' },
  { name: 'Wordfeud', href: '/wordfeud' },
  { name: 'Scrabble Go', href: '/scrabble-go' },
  { name: 'Hangman', href: '/hangman-solver' },
  { name: 'Word Search', href: '/word-search-solver' },
  { name: 'Word Scramble', href: '/word-scramble' },
  { name: 'Descrambler', href: '/descrambler' },
  { name: 'Word Finder', href: '/word-finder' },
  { name: 'Unlimited Wordle', href: '/wordle-unlimited' },
];
---

<!-- word.tips exact clone header -->
<header class="wt-header">
  <div class="wt-header-inner">

    <!-- Logo -->
    <a href="/" class="wt-logo" aria-label="WordTips Home">
      <span class="wt-logo-text">
        <span class="wt-logo-w">W</span>ord<span class="wt-logo-tips">Tips</span>
      </span>
    </a>

    <!-- Center Nav Links — word.tips style -->
    <nav class="wt-nav" aria-label="Main navigation">
      {mainNavLinks.map(link => (
        <a
          href={link.href}
          class={`wt-nav-link ${currentPath === link.href ? 'active' : ''}`}
        >
          {link.name}
        </a>
      ))}

      <!-- More dropdown -->
      <div class="wt-more-dropdown">
        <button class="wt-nav-link wt-more-btn" aria-expanded="false" aria-haspopup="true">
          More
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="wt-more-panel" role="menu">
          {moreLinks.map(link => (
            <a href={link.href} class="wt-more-item" role="menuitem">{link.name}</a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Right actions -->
    <div class="wt-header-right">

      <!-- Dark mode toggle -->
      <button type="button" class="wt-icon-btn" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <!-- Sun (shown in dark mode) -->
        <span id="icon-sun" class="hidden" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
        </span>
        <!-- Moon (shown in light mode) -->
        <span id="icon-moon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
      </button>

      <!-- Mobile hamburger -->
      <button type="button" class="wt-icon-btn wt-hamburger" id="mobile-menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-drawer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>

  </div>
</header>

<!-- Mobile Drawer -->
<div class="wt-mobile-drawer" id="mobile-drawer" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="wt-mobile-header">
    <span class="wt-logo-text"><span class="wt-logo-w">W</span>ord<span class="wt-logo-tips">Tips</span></span>
    <button type="button" class="wt-icon-btn" id="mobile-close-btn" aria-label="Close menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="wt-mobile-links">
    <div class="wt-mobile-section-label">Navigate</div>
    {[...mainNavLinks, ...moreLinks].map(link => (
      <a href={link.href} class="wt-mobile-link" data-close-drawer>{link.name}</a>
    ))}
    <div class="wt-mobile-section-label mt-3">Info</div>
    <a href="/about" class="wt-mobile-link" data-close-drawer>About</a>
    <a href="/contact" class="wt-mobile-link" data-close-drawer>Contact</a>
  </div>
</div>
<div class="wt-mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>

<script>
  (function () {
    // ── Theme toggle ────────────────────────────────────────────
    var themeKey = 'wordtips-theme-v2';
    var root = document.documentElement;
    function applyTheme(dark) {
      root.classList.toggle('dark', dark);
      var sun = document.getElementById('icon-sun');
      var moon = document.getElementById('icon-moon');
      if (sun) sun.classList.toggle('hidden', !dark);
      if (moon) moon.classList.toggle('hidden', dark);
      try { localStorage.setItem(themeKey, dark ? 'dark' : 'light'); } catch {}
    }
    var stored = localStorage.getItem(themeKey);
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    applyTheme(stored === 'dark' || (!stored && prefersDark));
    document.getElementById('theme-toggle').addEventListener('click', function () {
      applyTheme(!root.classList.contains('dark'));
    });

    // ── More dropdown ──────────────────────────────────────────
    var moreBtn = document.querySelector('.wt-more-btn');
    var morePanel = document.querySelector('.wt-more-panel');
    moreBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      var isOpen = moreBtn.getAttribute('aria-expanded') === 'true';
      moreBtn.setAttribute('aria-expanded', String(!isOpen));
    });
    document.addEventListener('click', function () {
      moreBtn.setAttribute('aria-expanded', 'false');
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') moreBtn.setAttribute('aria-expanded', 'false');
    });

    // ── Mobile drawer ──────────────────────────────────────────
    var drawer = document.getElementById('mobile-drawer');
    var overlay = document.getElementById('mobile-overlay');
    var openBtn = document.getElementById('mobile-menu-btn');
    var closeBtn = document.getElementById('mobile-close-btn');
    function openDrawer() {
      drawer.classList.add('is-open');
      overlay.classList.add('is-open');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      drawer.classList.remove('is-open');
      overlay.classList.remove('is-open');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    openBtn.addEventListener('click', openDrawer);
    closeBtn.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);
    drawer.querySelectorAll('[data-close-drawer]').forEach(function (el) {
      el.addEventListener('click', closeDrawer);
    });
  })();
</script>

<style>
  /* ── Header base — word.tips exact clone ────────────────── */
  .wt-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-base);
    border-bottom: 1px solid var(--border);
    width: 100%;
  }
  .wt-header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 3.5rem;
    display: flex;
    align-items: center;
    gap: 0;
  }

  /* ── Logo — word.tips style ──────────────────────────────── */
  .wt-logo {
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 2.5rem;
  }
  .wt-logo-text {
    font-size: 1.1875rem;
    font-weight: 800;
    color: var(--foreground);
    letter-spacing: -0.02em;
  }
  .wt-logo-w {
    color: var(--color-primary);
  }
  .wt-logo-tips {
    color: var(--color-primary);
  }

  /* ── Center Nav ─────────────────────────────────────────── */
  .wt-nav {
    display: flex;
    align-items: center;
    gap: 0;
    flex: 1;
  }
  .wt-nav-link {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--muted-foreground);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
  }
  .wt-nav-link:hover,
  .wt-nav-link.active {
    color: var(--foreground);
    background: var(--muted);
  }
  .wt-nav-link.active {
    color: var(--color-primary);
  }

  /* More button */
  .wt-more-dropdown {
    position: relative;
  }
  .wt-more-btn svg {
    margin-left: 0.25rem;
    transition: transform 0.2s;
  }
  .wt-more-dropdown:has([aria-expanded="true"]) .wt-more-btn svg {
    transform: rotate(180deg);
  }

  /* More panel */
  .wt-more-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 13rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s, transform 0.15s, visibility 0.15s;
    z-index: 200;
  }
  .wt-more-dropdown:hover .wt-more-panel,
  .wt-more-dropdown:focus-within .wt-more-panel,
  .wt-more-dropdown:has([aria-expanded="true"]) .wt-more-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .wt-more-item {
    display: block;
    padding: 0.4375rem 0.75rem;
    border-radius: var(--radius);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--foreground);
    text-decoration: none;
    transition: background 0.1s;
  }
  .wt-more-item:hover { background: var(--muted); }

  /* ── Right actions ─────────────────────────────────────── */
  .wt-header-right {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }
  .wt-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.125rem;
    height: 2.125rem;
    border-radius: var(--radius);
    border: none;
    background: none;
    color: var(--muted-foreground);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
  }
  .wt-icon-btn:hover {
    color: var(--foreground);
    background: var(--muted);
  }

  /* ── Mobile ──────────────────────────────────────────────── */
  .wt-hamburger { display: none; }
  @media (max-width: 900px) {
    .wt-nav { display: none; }
    .wt-hamburger { display: inline-flex; }
  }

  /* Mobile drawer */
  .wt-mobile-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(17rem, 90vw);
    background: var(--bg-card);
    border-left: 1px solid var(--border);
    z-index: 200;
    transform: translateX(100%);
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    overflow-y: auto;
  }
  .wt-mobile-drawer.is-open { transform: translateX(0); }
  .wt-mobile-overlay {
    position: fixed;
    inset: 0;
    background: rgb(0 0 0 / 0.4);
    z-index: 199;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s, visibility 0.25s;
  }
  .wt-mobile-overlay.is-open { opacity: 1; visibility: visible; }
  .wt-mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .wt-mobile-links { padding: 0.75rem; }
  .wt-mobile-section-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted-foreground);
    padding: 0.375rem 0.5rem 0.5rem;
  }
  .wt-mobile-link {
    display: block;
    padding: 0.5rem 0.625rem;
    border-radius: var(--radius);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--foreground);
    text-decoration: none;
    transition: background 0.1s;
  }
  .wt-mobile-link:hover { background: var(--muted); }
  .wt-mobile-section-label + .wt-mobile-link { margin-top: 0; }
  .mt-3 { margin-top: 0.75rem; }
</style>
