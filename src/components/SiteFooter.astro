---
const year = new Date().getFullYear();

const popularTools = [
  { name: 'Word Unscrambler', href: '/word-unscrambler' },
  { name: 'Wordle Solver', href: '/wordle-solver' },
  { name: 'Scrabble Word Finder', href: '/scrabble' },
  { name: 'Anagram Solver', href: '/anagram-solver' },
  { name: 'Words With Friends Cheat', href: '/words-with-friends' },
  { name: 'Crossword Solver', href: '/crossword-solver' },
  { name: 'Word Finder', href: '/word-finder' },
  { name: 'Descrambler', href: '/descrambler' },
];

const popularGames = [
  { name: 'Play Wordle', href: '/play-wordle' },
  { name: 'Unlimited Wordle', href: '/wordle-unlimited' },
  { name: 'Words With Friends', href: '/words-with-friends' },
  { name: 'Wordle', href: '/wordle' },
  { name: 'Word Cookies', href: '/word-cookies' },
  { name: 'Scrabble Go', href: '/scrabble-go' },
  { name: 'Boggle Solver', href: '/boggle-solver' },
  { name: 'Wordscapes', href: '/wordscapes' },
];

const infoLinks = [
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
  { name: 'Privacy Policy', href: '/privacy-policy' },
  { name: 'Terms of Use', href: '/terms' },
  { name: 'Word Lists', href: '/words-by-length' },
  { name: 'Words Start With', href: '/words-start-with' },
  { name: 'Words Ending In', href: '/words-ending-in' },
  { name: 'Words With Letters', href: '/words-with-letters' },
];

const wordLists = [
  { name: '2-Letter Words', href: '/2-letter-words' },
  { name: '3-Letter Words', href: '/3-letter-words' },
  { name: '4-Letter Words', href: '/4-letter-words' },
  { name: '5-Letter Words', href: '/5-letter-words' },
  { name: '6-Letter Words', href: '/6-letter-words' },
  { name: '7-Letter Words', href: '/7-letter-words' },
];

const resources = [
  { name: 'Word Generator', href: '/word-generator' },
  { name: 'Word Solver', href: '/word-solver' },
  { name: 'Word Search Solver', href: '/word-search-solver' },
  { name: 'Hangman Solver', href: '/hangman-solver' },
  { name: 'Letter Boxed Solver', href: '/letter-boxed-solver' },
  { name: 'Jumble Solver', href: '/jumble-solver' },
];

---

<footer class="wt-footer">
  <div class="wt-footer-inner">

    <!-- Brand column -->
    <div class="wt-footer-col">
      <div class="wt-footer-brand">
        <img src="/site-logo.png" alt="Word Unscrambler" class="wt-footer-logo" />
        <p class="wt-footer-tagline">
          Find better words faster. Free solvers, word lists, and puzzle helpers for everyday play.
        </p>
      </div>
    </div>

    <!-- Popular Tools -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Popular Tools</h3>
      <ul class="wt-footer-links">
        {popularTools.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Popular Games -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Popular Games</h3>
      <ul class="wt-footer-links">
        {popularGames.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Word Lists -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Words by Length</h3>
      <ul class="wt-footer-links">
        {wordLists.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Resources -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Resources</h3>
      <ul class="wt-footer-links">
        {resources.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Info -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Info</h3>
      <ul class="wt-footer-links">
        {infoLinks.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

  </div>

  <div class="wt-footer-bottom">
    <div class="wt-footer-bottom-inner">
      <p class="wt-footer-copy">
        &copy; {year} WordTips. All rights reserved.
      </p>
      <p class="wt-footer-disclaimer">
        This site is independent and is not affiliated with NYT, Hasbro, Zynga, or other word game publishers.
      </p>
    </div>
  </div>
</footer>

<style>
  /* word.tips footer clone */
  .wt-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }
  .wt-footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3.25rem 1.5rem 2.25rem;
    display: grid;
    grid-template-columns: 1.45fr repeat(5, minmax(0, 1fr));
    gap: 2.25rem 1.5rem;
  }
  @media (max-width: 1200px) {
    .wt-footer-inner {
      grid-template-columns: 1.5fr repeat(3, minmax(0, 1fr));
    }
  }
  @media (max-width: 900px) {
    .wt-footer-inner {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1.75rem 1.25rem;
    }
  }
  @media (max-width: 640px) {
    .wt-footer-inner {
      grid-template-columns: 1fr 1fr;
      padding: 2.5rem 1rem 1.75rem;
      gap: 1.5rem 1rem;
    }
  }
  @media (max-width: 480px) {
    .wt-footer-inner {
      grid-template-columns: 1fr;
    }
  }

  /* Brand */
  .wt-footer-brand { margin-bottom: 1.25rem; }
  .wt-footer-logo {
    display: block;
    width: min(240px, 100%);
    height: auto;
    object-fit: contain;
    margin-bottom: 0.75rem;
  }
  .wt-footer-tagline {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    line-height: 1.65;
    margin: 0;
    max-width: 22rem;
  }
  .wt-footer-social {
    display: flex;
    gap: 0.5rem;
  }
  .wt-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius);
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .wt-social-link:hover {
    color: var(--foreground);
    background: var(--muted);
  }

  /* Columns */
  .wt-footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--foreground);
    margin: 0 0 0.9rem;
  }
  .wt-footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .wt-footer-link {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    text-decoration: none;
    line-height: 1.45;
    transition: color 0.15s ease;
  }
  .wt-footer-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Bottom bar */
  .wt-footer-bottom {
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
  }
  .wt-footer-bottom-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    justify-content: space-between;
    align-items: center;
  }
  @media (max-width: 640px) {
    .wt-footer-bottom-inner {
      padding: 1rem;
      justify-content: center;
      text-align: center;
      gap: 0.4rem;
    }
  }
  .wt-footer-copy {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    margin: 0;
  }
  .wt-footer-disclaimer {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    margin: 0;
    opacity: 0.7;
  }
</style>
