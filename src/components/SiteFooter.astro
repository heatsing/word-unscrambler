---
const year = new Date().getFullYear();

const popularTools = [
  { name: 'Word Unscrambler', href: '/word-unscrambler' },
  { name: 'Wordle Solver', href: '/wordle-solver' },
  { name: 'Scrabble Word Finder', href: '/scrabble' },
  { name: 'Anagram Solver', href: '/anagram-solver' },
  { name: 'Words With Friends Cheat', href: '/words-with-friends' },
  { name: 'Crossword Solver', href: '/crossword-solver' },
  { name: 'Jumble Solver', href: '/jumble-solver' },
  { name: 'Text Twist Solver', href: '/text-twist' },
];

const popularGames = [
  { name: 'Play Wordle', href: '/play-wordle' },
  { name: 'Unlimited Wordle', href: '/wordle-unlimited' },
  { name: 'Words With Friends', href: '/words-with-friends' },
  { name: 'Word Cookies', href: '/word-cookies' },
  { name: 'Scrabble Go', href: '/scrabble-go' },
  { name: 'Boggle Solver', href: '/boggle-solver' },
  { name: 'Text Twist', href: '/text-twist' },
  { name: 'Wordscapes', href: '/wordscapes' },
];

const infoLinks = [
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
  { name: 'Privacy Policy', href: '/privacy-policy' },
  { name: 'Terms of Use', href: '/terms' },
];
---

<footer class="wt-footer">
  <div class="wt-footer-inner">

    <!-- Brand column -->
    <div class="wt-footer-col">
      <div class="wt-footer-brand">
        <span class="wt-footer-logo"><span class="wt-logo-w">W</span>ord<span class="wt-logo-tips">Tips</span></span>
        <p class="wt-footer-tagline">
          Free word game tools and solvers — no sign-up needed.
        </p>
      </div>
      <div class="wt-footer-social">
        <!-- Twitter/X -->
        <a href="#" class="wt-social-link" aria-label="Twitter" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <!-- Facebook -->
        <a href="#" class="wt-social-link" aria-label="Facebook" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>
    </div>

    <!-- Popular Tools -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Popular Tools</h3>
      <ul class="wt-footer-links">
        {popularTools.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Popular Games -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Popular Games</h3>
      <ul class="wt-footer-links">
        {popularGames.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Info -->
    <div class="wt-footer-col">
      <h3 class="wt-footer-heading">Info</h3>
      <ul class="wt-footer-links">
        {infoLinks.map(link => (
          <li><a href={link.href} class="wt-footer-link">{link.name}</a></li>
        ))}
      </ul>
    </div>

  </div>

  <div class="wt-footer-bottom">
    <div class="wt-footer-bottom-inner">
      <p class="wt-footer-copy">
        &copy; {year} WordTips. All rights reserved.
      </p>
      <p class="wt-footer-disclaimer">
        WordTips is not affiliated with any word game company. All trademarks are property of their respective owners.
      </p>
    </div>
  </div>
</footer>

<style>
  /* word.tips footer clone */
  .wt-footer {
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
    margin-top: 4rem;
  }
  .wt-footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 2rem;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2.5rem;
  }
  @media (max-width: 900px) {
    .wt-footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  @media (max-width: 560px) {
    .wt-footer-inner {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }

  /* Brand */
  .wt-footer-brand { margin-bottom: 1.25rem; }
  .wt-footer-logo {
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--foreground);
    letter-spacing: -0.02em;
    display: block;
    margin-bottom: 0.625rem;
  }
  .wt-logo-w { color: var(--color-primary); }
  .wt-logo-tips { color: var(--color-primary); }
  .wt-footer-tagline {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    line-height: 1.6;
    margin: 0;
  }
  .wt-footer-social {
    display: flex;
    gap: 0.5rem;
  }
  .wt-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius);
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }
  .wt-social-link:hover {
    color: var(--foreground);
    background: var(--muted);
  }

  /* Columns */
  .wt-footer-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--foreground);
    margin: 0 0 1rem;
  }
  .wt-footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .wt-footer-link {
    font-size: 0.875rem;
    color: var(--muted-foreground);
    text-decoration: none;
    transition: color 0.15s;
  }
  .wt-footer-link:hover { color: var(--color-primary); }

  /* Bottom bar */
  .wt-footer-bottom {
    border-top: 1px solid var(--border);
    background: var(--bg-secondary);
  }
  .wt-footer-bottom-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
    justify-content: space-between;
    align-items: center;
  }
  .wt-footer-copy {
    font-size: 0.8125rem;
    color: var(--muted-foreground);
    margin: 0;
  }
  .wt-footer-disclaimer {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    margin: 0;
    opacity: 0.7;
  }
</style>
