---
interface Props {
  title: string;
  description: string;
  tone?: "info" | "success" | "warning";
}

const { title, description, tone = "info" } = Astro.props;

const toneClass =
  tone === "success"
    ? "border-emerald-300 bg-emerald-50 text-emerald-900"
    : tone === "warning"
      ? "border-amber-300 bg-amber-50 text-amber-900"
      : "border-sky-300 bg-sky-50 text-sky-900";
---

<article class:list={["rounded-xl border p-4", toneClass]}>
  <h2 class="text-base font-bold">{title}</h2>
  <p class="mt-1 text-sm leading-6">{description}</p>
  <div class="mt-3">
    <slot />
  </div>
</article>
