---
const adClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
const adSlot = import.meta.env.PUBLIC_ADSENSE_SLOT ?? '';
const adsEnabled = adClient.startsWith('ca-pub-') && adSlot.trim().length > 0;
---
{
  adsEnabled && (
    <aside class="ad-slot" aria-label="Advertisement">
      <script async src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adClient}`} crossorigin="anonymous"></script>
      <ins class="adsbygoogle ad-slot-ins"
           style="display:block"
           data-ad-client={adClient}
           data-ad-slot={adSlot}
           data-ad-format="auto"
           data-full-width-responsive="true">
      </ins>
      <script>
        try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch (e) {}
      </script>
    </aside>
  )
}
