---
import Layout from '@/layouts/Layout.astro';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema } from '@/lib/schema';

const meta = getMeta(
  '/wordle',
  'Wordle - Daily Word Game Guide & Solver Tips',
  'Learn how to play Wordle, the viral daily word game. Get tips, strategies, and use our Wordle solver to find answers.'
);

const BEST_STARTING_WORDS = ['SLATE', 'CRANE', 'TRACE', 'AUDIO', 'ADIEU', 'RAISE', 'STARE', 'SOARE', 'LARES', 'RALES'];

const faqs = [
  {
    question: 'What is Wordle?',
    answer: 'Wordle is a popular daily word game where you have six attempts to guess a secret five-letter word. After each guess, you receive color-coded feedback: green means the letter is in the correct spot, yellow means the letter is in the word but in the wrong position, and gray means the letter is not in the word at all.',
  },
  {
    question: 'How do I play Wordle?',
    answer: 'Type a five-letter word as your first guess and press Enter. The game will color-code each letter: green for correct position, yellow for wrong position, and gray for letters not in the word. Use these clues to narrow down the answer within six tries.',
  },
  {
    question: 'What are the best starting words for Wordle?',
    answer: 'The most effective Wordle starting words include SLATE, CRANE, TRACE, AUDIO, ADIEU, RAISE, STARE, SOARE, LARES, and RALES. These words use common vowels and consonants to give you the most information in a single guess.',
  },
  {
    question: 'Can I play Wordle without an account?',
    answer: 'Yes! No sign-up required — just visit our <a href="/play-wordle" class="text-primary hover:underline">Play Wordle</a> page and start guessing.',
  },
  {
    question: 'How does the Wordle solver help?',
    answer: 'Our <a href="/wordle-solver" class="text-primary hover:underline">Wordle solver</a> lets you enter your known letters and excluded letters to find every possible matching word. This helps you narrow down the answer quickly.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta} fullBleed={true}>
  <div class="tool-page-skin">
    <section class="tool-hero">
      <div class="tool-hero-inner page-wrapper">
        <div class="breadcrumb">
          <a href="/">Home</a> <span>›</span> <a href="/">Daily Games</a> <span>›</span> <span class="current">Wordle</span>
        </div>
        <h1 class="page-h1">Wordle</h1>
        <p class="page-body">
          The viral daily word game. Guess the secret five-letter word in six tries and use color clues to solve efficiently.
        </p>
        <div class="page-tool-card">
          <div class="flex flex-wrap gap-3">
            <a href="/play-wordle" class="btn btn-primary text-base px-6 py-3">▶ Play Wordle Now</a>
            <a href="/wordle-unlimited" class="btn text-base px-6 py-3">∞ Unlimited Mode</a>
            <a href="/wordle-solver" class="btn text-base px-6 py-3">🧩 Solver</a>
          </div>
        </div>
      </div>
    </section>

    <div class="tool-content">
      <div class="page-wrapper">

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
    <section class="p-6 rounded-lg border border-border bg-card">
      <h2 class="text-2xl font-bold mb-4 text-foreground flex items-center gap-2">
        <span>📖</span> What is Wordle?
      </h2>
      <p class="text-muted-foreground text-[15px] leading-relaxed">
        Wordle is a browser-based word game created by Josh Wardle in 2021 and later acquired by The New York Times. Each day, a new five-letter word is published as the official puzzle. The game went viral through social media sharing of results — players post colored emoji grids showing how many guesses it took them to solve.
      </p>
      <p class="text-muted-foreground text-[15px] leading-relaxed mt-3">
        The beauty of Wordle is its simplicity: no accounts, no timers — just a fresh five-letter puzzle every 24 hours. Millions of people play alongside friends, family, and coworkers every single day.
      </p>
      <div class="mt-4 flex gap-2 flex-wrap">
        <a href="/play-wordle" class="btn btn-primary text-sm">▶ Play Now</a>
        <a href="/wordle-solver" class="btn text-sm">🧩 Solver</a>
      </div>
    </section>

    <section class="p-6 rounded-lg border border-border bg-card">
      <h2 class="text-2xl font-bold mb-4 text-foreground flex items-center gap-2">
        <span>🎮</span> How It Works
      </h2>
      <div class="space-y-4">
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm">1</div>
          <div>
            <p class="font-semibold text-foreground text-[15px]">Guess any 5-letter word</p>
            <p class="text-muted-foreground text-sm">Start with a word that has common vowels and consonants.</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm">2</div>
          <div>
            <p class="font-semibold text-foreground text-[15px]">Read the color clues</p>
            <p class="text-muted-foreground text-sm">Tiles flip to show green (correct), yellow (wrong pos), or gray (not in word).</p>
          </div>
        </div>
        <div class="flex items-start gap-3">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold text-sm">3</div>
          <div>
            <p class="font-semibold text-foreground text-[15px]">Solve in 6 tries or fewer</p>
            <p class="text-muted-foreground text-sm">Use logic to narrow down possibilities and find the daily word.</p>
          </div>
        </div>
        <div class="mt-4 p-4 rounded-lg bg-muted/50">
          <p class="text-sm font-semibold text-foreground mb-2">Example:</p>
          <div class="flex gap-1">
            <div class="w-10 h-10 border-2 border-[#c9b458] bg-[#c9b458] rounded flex items-center justify-center text-white font-bold text-lg">C</div>
            <div class="w-10 h-10 border-2 border-[#787c7e] bg-[#787c7e] rounded flex items-center justify-center text-white font-bold text-lg">R</div>
            <div class="w-10 h-10 border-2 border-[#787c7e] bg-[#787c7e] rounded flex items-center justify-center text-white font-bold text-lg">A</div>
            <div class="w-10 h-10 border-2 border-[#6aaa64] bg-[#6aaa64] rounded flex items-center justify-center text-white font-bold text-lg">N</div>
            <div class="w-10 h-10 border-2 border-[#787c7e] bg-[#787c7e] rounded flex items-center justify-center text-white font-bold text-lg">E</div>
          </div>
          <p class="text-xs text-muted-foreground mt-2">C = wrong position, R/A/E = not in word, N = correct!</p>
        </div>
      </div>
    </section>
  </div>

  <section class="mb-10 p-6 rounded-lg border border-border bg-card">
    <h2 class="text-2xl font-bold mb-4 text-foreground flex items-center gap-2">
      <span>💡</span> Tips & Strategies
    </h2>
    <ul class="space-y-2 text-[15px] text-muted-foreground leading-relaxed">
      <li class="flex items-start gap-2">
        <span class="text-primary mt-0.5">→</span>
        <p><strong class="text-foreground">Start with vowel-rich words.</strong> Words like <strong class="text-foreground">ADIEU</strong> or <strong class="text-foreground">AUDIO</strong> reveal whether common vowels (A, E, I, O, U) are in the puzzle.</p>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-primary mt-0.5">→</span>
        <p><strong class="text-foreground">Eliminate common consonants early.</strong> Letters like R, S, T, L, and N appear in most five-letter words.</p>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-primary mt-0.5">→</span>
        <p><strong class="text-foreground">Watch for double letters.</strong> Many words contain repeated letters (e.g., SPEED, LULLS).</p>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-primary mt-0.5">→</span>
        <p><strong class="text-foreground">Don't waste letters you know are wrong.</strong> Once gray, don't include them in future guesses.</p>
      </li>
      <li class="flex items-start gap-2">
        <span class="text-primary mt-0.5">→</span>
        <p><strong class="text-foreground">Use the <a href="/wordle-solver" class="text-primary hover:underline">Wordle solver</a></strong> when stuck — enter your known letters to find all matching words.</p>
      </li>
    </ul>
  </section>

  <section class="mb-10 p-6 rounded-lg border border-border bg-card">
    <h2 class="text-2xl font-bold mb-4 text-foreground flex items-center gap-2">
      <span>🏆</span> Best Starting Words
    </h2>
    <p class="text-muted-foreground text-[15px] mb-5">
      These opening words maximize vowel and consonant coverage for the most information per guess.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
      {BEST_STARTING_WORDS.map((word) => (
        <a
          href={`/wordle-solver?q=${word.toLowerCase()}`}
          class="flex items-center justify-center py-3 px-4 rounded-lg border border-border bg-muted/30 text-foreground font-mono font-bold text-lg hover:bg-primary hover:text-primary-foreground hover:border-primary transition-colors"
        >
          {word}
        </a>
      ))}
    </div>
  </section>

  <AdSense />

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]">{faq.question}</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>

  <nav class="mt-10 flex flex-wrap gap-4 text-sm text-muted-foreground">
    <a href="/play-wordle" class="hover:text-foreground transition-colors">▶ Play Daily Wordle →</a>
    <a href="/wordle-unlimited" class="hover:text-foreground transition-colors">∞ Unlimited Wordle →</a>
    <a href="/wordle-solver" class="hover:text-foreground transition-colors">🧩 Wordle Solver →</a>
    <a href="/anagram-solver" class="hover:text-foreground transition-colors">Anagram Solver →</a>
  </nav>

      </div>
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
