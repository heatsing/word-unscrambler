---
import Layout from '@/layouts/Layout.astro';
import CrosswordSolver from '@/components/CrosswordSolver';
import AdSense from '@/components/AdSense';
import InternalLinks from '@/components/InternalLinks.astro';
import SeoSchemaBlocks from '@/components/SeoSchemaBlocks.astro';
import { getMeta } from '@/lib/meta';

const meta = getMeta(
  '/crossword-solver',
  'Crossword Solver - Find Answers to Any Clue | Free Tool',
  'Free crossword solver: enter letter patterns with underscores for unknown letters and find every matching word. Works for any crossword puzzle difficulty.'
);

const howToSteps = [
  { name: 'Enter your letter pattern', text: 'Type the letters you know and use underscores (_) for each unknown position. For example: _A_E matches 5-letter words where you know the 2nd and 4th letters.' },
  { name: 'Set the word length', text: 'Select how many letters the answer should have from the dropdown (2-10 letters).' },
  { name: 'Add letters you know exist (optional)', text: 'Use the "Include letters" field to enter letters that must appear in the word, even if you don\'t know their position.' },
  { name: 'Find your answer', text: 'Click Find Words to see every word matching your pattern, sorted by relevance. Combine with the clue definition to find the right answer.' },
];

const faqs = [
  {
    question: 'How does the crossword solver work?',
    answer: 'The crossword solver takes your letter pattern (with underscores for unknown positions) and searches a comprehensive dictionary for every word that matches. For example, if you know the answer is a 5-letter word with A as the second letter and E as the fourth — pattern <strong class="text-foreground">_A_E</strong> — the solver finds every word matching that pattern.',
  },
  {
    question: 'What do underscores mean in the crossword solver?',
    answer: 'Each underscore (_) represents exactly one unknown letter at that position. You can use as many underscores as you need — one underscore per unknown letter. For example, "__ING" matches any 6-letter word ending in -ING.',
  },
  {
    question: 'Can I solve crossword clues with this tool?',
    answer: 'This tool solves the <em>letter pattern</em> part of crosswords. It doesn\'t have a clue database — but once you parse the clue definition, the letter pattern is often the hardest part. Use the Crossword Solver to find all words matching your pattern, then cross-reference with the clue meaning.',
  },
  {
    question: 'What\'s the best strategy for difficult crossword patterns?',
    answer: '1. <strong class="text-foreground">Start with position clues</strong> — If you know a letter at any position, enter it. Even one confirmed letter dramatically narrows results. 2. <strong class="text-foreground">Use the include filter</strong> — If the word has a repeated letter, enter it in the "Include" field. 3. <strong class="text-foreground">Work systematically</strong> — Try the most common letters in the unknowns. 4. <strong class="text-foreground">Think about word families</strong> — Once you narrow the pattern, consider what types of words fit the clue: verb, noun, adjective, etc.',
  },
  {
    question: 'Does the crossword solver work for any word length?',
    answer: 'Yes! Our crossword solver works for word lengths from 2 to 10 letters, covering the vast majority of standard crossword grid sizes. For longer words (10+ letters), try our main <a href="/word-unscrambler" class="text-primary hover:underline">word unscrambler</a>.',
  },
  {
    question: 'How is this different from a word unscrambler?',
    answer: 'A word unscrambler takes a set of letters and finds every word you can make from them — order doesn\'t matter. A crossword solver finds words matching a <em>specific pattern</em> where you know some positions and others are unknown.',
  },
];

---

<Layout meta={meta} fullBleed={true}>
<div class="tool-page-skin">
<section class="tool-hero">
<div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Crossword Solver</h1>
  <p class="page-body">Enter your crossword letter pattern with underscores for unknown letters. Find every word matching your pattern — instantly. Supports up to 3 wildcards (? or space).</p>

  <div class="page-tool-card">
    <CrosswordSolver client:load />
  </div>
</div>
</section>

<div class="tool-content">

<AdSense />

<div class="page-wrapper">
  <h2 class="page-h2">What is a Crossword Solver?</h2>
  <div class="page-body">
    <p>A crossword solver is a tool that helps you find words matching a specific <em>letter pattern</em> when you're stuck on a crossword puzzle. If you know some of the letters in an answer but not all of them, enter the pattern with underscores for the unknown positions and the solver finds every matching word from our dictionary.</p>
    <p>The crossword solver is different from a word unscrambler: unscramblers find words from a set of letters without caring about order, while a crossword solver finds words matching a <em>specific pattern</em> where you know some positions and not others.</p>
  </div>

  <h2 class="page-h2">How to Use the Crossword Helper</h2>
  <div class="page-tool-card">
    <div class="space-y-5">
      {howToSteps.map((step, i) => (
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">{i + 1}</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">{step.name}</h3>
            <p class="text-sm text-muted-foreground">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-6 p-4 bg-primary/5 border border-primary/20 rounded-xl">
      <p class="text-sm text-muted-foreground">
        <strong class="text-foreground">Pattern examples:</strong>
        <code class="ml-2 font-mono text-foreground">_A_E</code> = 5 letters, 2nd=A, 4th=E ·
        <code class="ml-2 font-mono text-foreground">__ING</code> = 6 letters, ends with ING ·
        <code class="ml-2 font-mono text-foreground">S__T</code> = 4 letters, starts S, ends T
      </p>
    </div>
  </div>

  <h2 class="page-h2">Crossword Solving Tips</h2>
  <div class="page-body">
    <p><strong>1. Start with pattern-first clues:</strong> Crossword clues that describe a specific letter pattern are the easiest to solve with our tool. Enter the pattern immediately and find your answer before reading the definition.</p>
    <p><strong>2. Use the include filter for repeated letters:</strong> If you know the word has two identical letters (like "ELEPHANT" with two E's), enter that letter in the "Include" field. This filters out words that don't have the repeated letter.</p>
    <p><strong>3. Check both directions:</strong> In a crossword grid, the same cell is part of two different words — one horizontal, one vertical. If you're stuck on one direction, solve the other first.</p>
    <p><strong>4. Think about word families:</strong> If your pattern matches multiple words, use the clue's part of speech (noun, verb, adjective) to narrow.</p>
    <p><strong>5. Use our word unscrambler for the crossing letters:</strong> If you're stuck on a crossing word, use our <a href="/word-unscrambler" class="text-primary hover:underline">word unscrambler</a> to find words from those letters.</p>
  </div>

  <h2 class="page-h2">Common Crossword Patterns</h2>
  <div class="page-body">
    <p>These common crossword word patterns appear frequently. Use them to quickly identify answers:</p>
  </div>
  <div class="page-tool-card">
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {[
        { pattern: '__ING', meaning: 'Present participle' },
        { pattern: '__ED', meaning: 'Past tense' },
        { pattern: '__ER', meaning: 'Agent/noun' },
        { pattern: '__LY', meaning: 'Adverb' },
        { pattern: '__TION', meaning: 'Noun ending' },
        { pattern: '__NESS', meaning: 'State of being' },
        { pattern: 'UN___', meaning: 'Opposite + root' },
        { pattern: 'RE___', meaning: 'Again prefix' },
        { pattern: '_O_', meaning: '3 letters, O is middle' },
        { pattern: '__ (2 letters)', meaning: 'AT, OF, IN, ON, TO, BY' },
        { pattern: '___ (3 letters)', meaning: 'THE, AND, FOR, ARE, BUT' },
        { pattern: '____ (4 letters)', meaning: 'THAT, WITH, HAVE, FROM' },
      ].map(({ pattern, meaning }) => (
        <div class="p-3 rounded-xl border border-border bg-muted/30">
          <code class="font-mono font-bold text-primary text-sm">{pattern}</code>
          <p class="text-xs text-muted-foreground mt-1">{meaning}</p>
        </div>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Related Word Tools</h2>
  <div class="page-body">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: 'Word Unscrambler', href: '/word-unscrambler', icon: '🔤' },
        { name: 'Anagram Solver', href: '/anagram-solver', icon: '📚' },
        { name: 'Wordle Solver', href: '/wordle-solver', icon: '🎯' },
        { name: 'Scrabble Finder', href: '/scrabble', icon: '🎲' },
      ].map((tool) => (
        <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-background hover:border-primary/50 hover:shadow-sm transition-all group">
          <span class="text-xl">{tool.icon}</span>
          <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
        </a>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]" set:html={faq.question} />
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>
  <InternalLinks />
</div>
<SeoSchemaBlocks faqs={faqs} howToSteps={howToSteps} />
</div>
</div>
</Layout>
