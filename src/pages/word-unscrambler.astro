---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema, getHowToSchema } from '@/lib/schema';

const meta = getMeta(
  '/word-unscrambler',
  'Word Unscrambler - Free Tool to Unscramble Words Instantly',
  'Free word unscrambler: enter scrambled letters and get every valid word you can make. Works for Scrabble, crosswords, Wordle, anagrams, and all word games.'
);

const howToSteps = [
  { name: 'Enter your letters', text: 'Type any set of letters — 2 to 15+ letters. Works with scrambled, jumbled, or any arrangement of letters.' },
  { name: 'Browse your results', text: 'Results appear instantly, sorted by Scrabble score (highest first). Find the word you need.' },
  { name: 'Filter by length (optional)', text: 'Use the Min and Max length controls to filter results to a specific word size.' },
  { name: 'Use in your game', text: 'Find the word you need and play it in your game. No sign-up, no download — just instant results.' },
];

const howToSchema = getHowToSchema(howToSteps);

const faqs = [
  {
    question: 'What is a word unscrambler?',
    answer: 'A word unscrambler is a free online tool that takes any set of scrambled, jumbled, or mixed-up letters and finds every valid English word you can make from them. Whether you have 3 letters like "ABC" or 15 letters like a full word scramble puzzle, our unscrambler instantly checks every possible arrangement against a comprehensive dictionary. Enter your letters and get results sorted by Scrabble score.',
  },
  {
    question: 'How does the word unscrambler work?',
    answer: 'Enter your scrambled letters and the solver checks every possible arrangement against a comprehensive English dictionary, finding every valid word that can be made from those letters. It\'s essentially a fast dictionary lookup that handles any letter combination — no matter how jumbled. Results are sorted by Scrabble score so your highest-scoring plays appear first.',
  },
  {
    question: 'What games can I use this for?',
    answer: 'Our word unscrambler works for virtually every word game: <a href="/scrabble" class="text-primary hover:underline">Scrabble</a>, <a href="/scrabble-go" class="text-primary hover:underline">Scrabble Go</a>, <a href="/words-with-friends" class="text-primary hover:underline">Words With Friends</a>, <a href="/wordfeud" class="text-primary hover:underline">Wordfeud</a>, <a href="/word-cookies" class="text-primary hover:underline">Word Cookies</a>, <a href="/text-twist" class="text-primary hover:underline">Text Twist</a>, <a href="/wordscapes" class="text-primary hover:underline">Wordscapes</a>, <a href="/boggle-solver" class="text-primary hover:underline">Boggle</a>, crosswords, anagrams, and more.',
  },
  {
    question: 'How many letters can the word unscrambler handle?',
    answer: 'Our word unscrambler handles 2 to 15+ letters. Short inputs (3-5 letters) are instant. Longer inputs (10+ letters) may take a fraction of a second as the solver checks billions of possible arrangements. Use the Min and Max length filters to narrow results to words of a specific size.',
  },
  {
    question: 'Can I use wildcards like blank tiles?',
    answer: 'Yes! Enter a question mark (?) as a wildcard to represent any letter you don\'t know. For example, entering "S?RATE" will find words like "STRATE", "SIRATE", "SERATE", and "SURATE" — as long as they\'re in the dictionary.',
  },
  {
    question: 'Is the word unscrambler free?',
    answer: 'Yes! Our word unscrambler is completely free to use with no sign-up, no download, and no limits. Use it as many times as you want on any device.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta}>
<div class="page-wrapper">
  <div class="breadcrumb">
    <a href="/">Home</a> <span>›</span> <a href="/">Tools</a> <span>›</span> <span class="current">Word Unscrambler</span>
  </div>

  <h1 class="page-h1">Word Unscrambler</h1>
  <p class="page-body">Free word unscrambler: enter scrambled letters and get every valid word you can make. Works for Scrabble, crosswords, Wordle, anagrams, and all word games.</p>

  <div class="page-tool-card">
    <UnscrambleTool client:load />
  </div>
</div>

<AdSense />

<div class="page-wrapper">
  <h2 class="page-h2">What is Word Unscrambler?</h2>
  <div class="page-body">
    <p>A word unscrambler is a free online tool that takes any set of scrambled, jumbled, or mixed-up letters and finds every valid English word hiding inside them. Whether you have a few random letters from a game like Text Twist, a full rack of Scrabble tiles, or a complete word scramble puzzle — enter the letters and get results instantly.</p>
    <p>The tool works by comparing every possible arrangement of your letters against a comprehensive English dictionary. With our unscrambler, you get every valid word sorted by score — so your highest-scoring plays appear first.</p>
    <p>Use it for <a href="/scrabble">Scrabble</a>, <a href="/scrabble-go">Scrabble Go</a>, <a href="/words-with-friends">Words With Friends</a>, <a href="/wordfeud">Wordfeud</a>, <a href="/text-twist">Text Twist</a>, <a href="/word-cookies">Word Cookies</a>, <a href="/wordscapes">Wordscapes</a>, and virtually any other word game or puzzle.</p>
  </div>

  <h2 class="page-h2">How to Use the Word Unscrambler</h2>
  <div class="page-body">
    <p>Using our word unscrambler is simple:</p>
  </div>
  <div class="page-tool-card">
    <div class="space-y-5">
      {howToSteps.map((step, i) => (
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">{i + 1}</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">{step.name}</h3>
            <p class="text-sm text-muted-foreground">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Tips for Unscrambling Words</h2>
  <div class="page-body">
    <p>Want to get better at unscrambling words without a tool? Here are expert strategies:</p>
    <p><strong>1. Look for common word patterns first.</strong> Vowel-consonant-vowel (VCV) patterns like A-E, I-O, U-A appear constantly in English. Common two-letter pairs: TH, HE, IN, ER, AN, RE, ON, AT, ST, ND.</p>
    <p><strong>2. Try common prefixes and suffixes.</strong> Words starting with UN-, RE-, IN-, OUT-, DIS-, PRE- and ending with -ING, -ED, -ER, -LY, -TION are extremely common in English.</p>
    <p><strong>3. Start with rare letters.</strong> Q, Z, X, J, and V are the rarest letters in English. If your scramble has a Q, look for QI, QAT, or QIS. Finding where rare letters go often narrows the answer quickly.</p>
    <p><strong>4. Watch for doubled letters.</strong> If your scramble has two identical letters (SS, TT, LL, EE, etc.), they're likely doubled in the original word. In "LATTE", the doubled TT points toward "TABLET".</p>
  </div>

  <h2 class="page-h2">Word Unscrambler for Every Word Game</h2>
  <div class="page-body">
    <p>Our word unscrambler works for any letter set, making it the ultimate tool for word games:</p>
    <p><strong>Scrabble:</strong> Enter your tiles and instantly see every valid word, sorted by Scrabble score. Find 7-letter Bingos, high-value Q/Z/J/X words, and the best plays for any board situation.</p>
    <p><strong>Words With Friends &amp; Wordfeud:</strong> The WWF and Wordfeud dictionaries are nearly identical to Scrabble. Our unscrambler covers both.</p>
    <p><strong>Text Twist:</strong> Enter the 6 letters from your Text Twist grid and find every 3, 4, 5, and 6-letter word hidden inside.</p>
    <p><strong>Word Cookies &amp; Wordscapes:</strong> Enter the letter batch from any level and see every valid word — including the hidden bonus word.</p>
    <p><strong>Anagram puzzles:</strong> Turn one word into another by rearranging letters. Our unscrambler shows you all possible arrangements.</p>
  </div>

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]">{faq.question}</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
</Layout>
