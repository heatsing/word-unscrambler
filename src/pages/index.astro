---
import Layout from '@/layouts/Layout.astro';
import WordsStartWithTool from '@/components/WordsStartWithTool';
import { getMeta, DEFAULT_TITLE, DEFAULT_DESCRIPTION } from '@/lib/meta';
import { getWebSiteSchema, getOrganizationSchema } from '@/lib/schema';
import {
  headerWordSolvers,
  headerWordLists,
  headerCrosswords,
} from '@/lib/nav-links';

const meta = getMeta('/', DEFAULT_TITLE, DEFAULT_DESCRIPTION);
const webSiteSchema = getWebSiteSchema();
const organizationSchema = getOrganizationSchema();

const fiveLetterLinks = [
  '5 Letter Words Starting with B',
  '5 Letter Words Starting with BE',
  '5 Letter Words Starting with BEG',
  '5 Letter Words with the Letter U',
  '5 Letter Words with the Letter EGU',
  '5 Letter Words with the Letter G',
  '5 Letter Words with the Letter EU',
  '5 Letter Words with the Letter E',
  '5 Letter Words with the Letter EG',
  '5 Letter Words with the Letter GU',
  '5 Letter Words Ending In UN',
  '5 Letter Words Ending In N',
  '5 Letter Words Ending In GUN',
];

const today = new Date();
const dateLabel = today.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const dailyHintsWithMeta = [
  { name: 'Connections', subtitle: 'Hints for each category & today\'s answers', href: '/jumble-solver', icon: '🧩' },
  { name: 'Wordle Hints', subtitle: 'Hints to crack today\'s puzzle', href: '/wordle', icon: '🟩' },
  { name: 'Pips Hints', subtitle: 'Domino solutions & tips', href: '/crossword-solver', icon: '🎲' },
  { name: 'Strands Hints', subtitle: 'Theme & spangram revealed', href: '/word-search-solver', icon: '🧶' },
  { name: 'Mini Crossword Answers', subtitle: 'All clues & answers', href: '/crossword-solver', icon: '🧠' },
  { name: 'Spelling Bee Answers', subtitle: 'Word list & pangrams', href: '/word-unscrambler', icon: '🐝' },
  { name: 'Contexto Answer', subtitle: 'Hints & secret word', href: '/word-finder', icon: '🧩' },
  { name: 'Capture Hints', subtitle: 'Step-by-step solutions', href: '/crossword-solver', icon: '🧭' },
];
---

<Layout meta={meta} fullBleed={true}>
  <div class="home-clone">
    <section class="home-hero">
      <div class="home-hero-inner">
        <h1 class="home-h1">Word Finder</h1>
        <p class="home-sub">Add your letters first</p>
        <WordsStartWithTool client:load />
      </div>
    </section>

    <section class="home-section">
      <div class="home-wrap">
        <h2 class="home-h2">5 Letter Words</h2>
        <p class="home-muted">5-letter word lists built for puzzle solving</p>
        <ul class="home-link-grid">
          {fiveLetterLinks.map((label) => (
            <li><a href="/words-by-length">{label}</a></li>
          ))}
          <li><a href="/words-start-with">Words that start with</a></li>
          <li><a href="/words-with-letters">Words with letters</a></li>
          <li><a href="/words-ending-in">Words ending in</a></li>
        </ul>
      </div>
    </section>

    <section class="home-section alt">
      <div class="home-wrap">
        <h2 class="home-h2">Word Games</h2>
        <p class="home-muted">Fun daily word games made by Wordtips</p>
        <div class="card-grid">
          <a class="game-card" href="/crossword-solver">
            <h3>WT Mini Crossword</h3>
            <p>Like NYT Mini, but free. Forever. No paywall.</p>
            <span>Play</span>
          </a>
          <a class="game-card" href="/wordle-unlimited">
            <h3>WordQuest</h3>
            <p>Unlimited Wordle with streaks & powerups.</p>
            <span>Play</span>
          </a>
          <a class="game-card" href="/wordle">
            <h3>WordQuest Daily</h3>
            <p>Today's puzzle with points and hints.</p>
            <span>Play</span>
          </a>
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="home-wrap">
        <h2 class="home-h2">Daily Word Games Hints & Answers</h2>
        <p class="home-muted">Keep your streak alive. Daily help for daily puzzles.</p>
        <div class="daily-grid">
          {dailyHintsWithMeta.map((item) => (
            <a class="daily-item" href={item.href}>
              <div class="daily-item-top">
                <span class="daily-item-icon" aria-hidden="true">{item.icon}</span>
                <div>
                  <strong>{item.name}</strong>
                  <span>{item.subtitle}</span>
                </div>
              </div>
              <em>{dateLabel}</em>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section alt">
      <div class="home-wrap">
        <h2 class="home-h2">Popular Word Games Solvers & Helpers</h2>
        <div class="card-grid">
          {headerWordSolvers.map((tool) => (
            <a class="game-card" href={tool.href}>
              <h3>{tool.name}</h3>
              <p>The ultimate helper to turn patterns into possibilities.</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="home-wrap">
        <h2 class="home-h2">Crossword Clues</h2>
        <ul class="clues-list">
          <li><a href="/crossword-solver">Fabric used for casino tables</a></li>
          <li><a href="/crossword-solver">Togetherness</a></li>
          <li><a href="/crossword-solver">Basic belief</a></li>
          <li><a href="/crossword-solver">Romantic rendezvous</a></li>
          <li><a href="/crossword-solver">Whac-A-___ (classic arcade game)</a></li>
          <li><a href="/crossword-solver">Dog breed favored by Queen Elizabeth II</a></li>
        </ul>
        <div class="mini-columns">
          <div>
            <h3>Word Lists</h3>
            <ul>{headerWordLists.map((l) => <li><a href={l.href}>{l.name}</a></li>)}</ul>
          </div>
          <div>
            <h3>Crosswords</h3>
            <ul>{headerCrosswords.map((l) => <li><a href={l.href}>{l.name}</a></li>)}</ul>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
</Layout>

<style>
  .home-clone { background: var(--background); color: var(--foreground); }
  .home-hero {
    background: linear-gradient(135deg, #79AE6F 0%, #346739 100%);
    padding: 2rem 1rem 2.75rem;
  }
  .home-hero-inner {
    max-width: 44rem;
    margin: 0 auto;
  }
  .home-h1 {
    margin: 0;
    text-align: center;
    color: #fff;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .home-sub {
    margin: 0.5rem 0 1.5rem;
    text-align: center;
    color: rgb(255 255 255 / 0.9);
    font-weight: 600;
  }
  .home-section { padding: 2.25rem 1rem; }
  .home-section.alt { background: var(--muted); }
  .home-wrap { max-width: 72rem; margin: 0 auto; }
  .home-h2 {
    margin: 0 0 0.4rem;
    font-size: clamp(1.35rem, 2.5vw, 2rem);
    font-weight: 800;
  }
  .home-muted { margin: 0 0 1rem; color: var(--muted-foreground); }
  .home-link-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  }
  .home-link-grid a, .clues-list a, .mini-columns a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
  }
  .home-link-grid a:hover, .clues-list a:hover, .mini-columns a:hover { text-decoration: underline; }
  .card-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .game-card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    padding: 1rem;
    background: var(--card);
    text-decoration: none;
    color: inherit;
  }
  .game-card h3 { margin: 0 0 0.35rem; font-size: 1.05rem; font-weight: 800; }
  .game-card p { margin: 0; color: var(--muted-foreground); line-height: 1.55; }
  .game-card span { display: inline-block; margin-top: 0.75rem; color: var(--color-primary); font-weight: 700; }
  .daily-grid {
    display: grid;
    gap: 0.75rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .daily-item {
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 0.8rem;
    background: var(--card);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .daily-item-top {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
  }
  .daily-item-icon {
    width: 1.4rem;
    height: 1.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .daily-item strong { font-size: 0.95rem; }
  .daily-item span { color: var(--muted-foreground); font-size: 0.86rem; display: block; margin-top: 0.05rem; }
  .daily-item em {
    color: var(--muted-foreground);
    opacity: 0.8;
    font-size: 0.78rem;
    font-style: normal;
    margin-top: 0.25rem;
  }
  .clues-list { margin: 0; padding-left: 1.1rem; display: grid; gap: 0.55rem; }
  .mini-columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 1rem;
    margin-top: 1.3rem;
  }
  .mini-columns h3 { margin: 0 0 0.4rem; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .mini-columns ul { margin: 0; padding-left: 1rem; display: grid; gap: 0.45rem; }
</style>
