---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema } from '@/lib/schema';

const meta = getMeta(
  '/hangman-solver',
  'Hangman Solver - Guess the Word',
  'Hangman solver: enter known letters and blank positions to find possible words. Works with any word length for solving Hangman puzzles.'
);

const faqs = [
  {
    question: 'How does the Hangman solver work?',
    answer: 'Enter the letters you know in their correct positions using underscores for unknown letters. For example, if you know the word is 5 letters and you know the 2nd letter is "A" and the last letter is "E", enter _A__E. The solver will show all matching words from our dictionary.',
  },
  {
    question: 'What format should I use for the Hangman solver?',
    answer: 'Use underscores (_) for each unknown letter and type the known letters in their exact positions. You can enter multiple known letters. The solver supports words from 2 to 10 letters long.',
  },
  {
    question: 'Can I use wildcards in the Hangman solver?',
    answer: 'Yes, you can use a question mark (?) as a wildcard for any single unknown letter. This is useful when you have multiple possible positions but want more flexible matching.',
  },
  {
    question: 'Is the Hangman solver free?',
    answer: 'Yes, our Hangman solver is completely free to use with no sign-up or download required. Just open the page and start guessing!',
  },
  {
    question: 'What strategies help with Hangman?',
    answer: 'Start with common letters: E, T, A, O, I, N, S, H, and R are the most frequent letters in English. Vowels are especially valuable early in the game. Focus on vowels early — words without vowels are rare. Consider word patterns — once you have several letters, look for common endings like -ING, -ED, -ER, -EST, -LY, and -ION.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta} fullBleed={true}>
<div class="tool-page-skin">
<section class="tool-hero">
<div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Hangman Solver</h1>
  <p class="page-body">Enter your known letters and blank positions to find all possible words. Solve any Hangman puzzle instantly.</p>

  <div class="page-tool-card">
    <UnscrambleTool client:load />
  </div>
</div>
</section>

<div class="tool-content">
<AdSense />

<div class="page-wrapper">
  <h2 class="page-h2">How to Solve Hangman</h2>
  <div class="page-body">
    <p>Hangman is a classic word guessing game where one player thinks of a word and the other tries to guess it letter by letter. Our Hangman solver helps you find the right word when you're stuck or want to challenge friends.</p>
    <p>Enter the letters you know in their correct positions using underscores for unknown letters. For example, if you know the word is 5 letters and you know the 2nd letter is "A" and the last letter is "E", enter <strong class="text-foreground">_A__E</strong>.</p>
  </div>

  <h2 class="page-h2">Hangman Strategies</h2>
  <div class="page-body">
    <p><strong>Start with common letters:</strong> E is the most common letter in English, followed by T, A, O, I, N, S, H, and R. These give you the best chance of hitting the word early.</p>
    <p><strong>Focus on vowels early:</strong> Words without vowels are rare. Getting the vowels (A, E, I, O, U) figured out quickly narrows down the possibilities dramatically.</p>
    <p><strong>Use letter frequency:</strong> After vowels, common consonants include S, T, N, L, R, H, D, C, and M. Avoid rare letters like Q, Z, X, J, and K unless you have a strong reason to include them.</p>
    <p><strong>Consider word patterns:</strong> Once you have several letters, look for common endings like -ING, -ED, -ER, -EST, -LY, and -ION. These can quickly reveal the word.</p>
    <p><strong>Think of categories:</strong> If you know the word is an animal, food, or place, you can focus your guessing on relevant vocabulary.</p>
  </div>

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]">{faq.question}</span>
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p>{faq.answer}</p>
        </div>
      </details>
    ))}
  </div>
</div>
</div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
