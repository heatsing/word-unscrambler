---
import Layout from '@/layouts/Layout.astro';
import WordsStartWithTool from '@/components/WordsStartWithTool';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema, getHowToSchema } from '@/lib/schema';

const meta = getMeta(
  '/word-scramble',
  'Word Scramble - Word Finder | Unscramble Letters & Wildcards',
  'Word scramble finder: enter your letters with up to 3 wildcards (? or space). Filter by starts, ends, contains, and length. NYT Crossplay, Words With Friends, Scrabble US/UK, or all dictionaries.'
);

const howToSteps = [
  { name: 'Enter your letters', text: 'Type scrambled letters in the main field. Use ? or space for up to three wildcards when you are missing tiles.' },
  { name: 'Add filters (optional)', text: 'Use Starts, Ends, Contains, and Length to match board slots or clues. Exclude or Include letters if you need extra constraints.' },
  { name: 'Pick a dictionary and search', text: 'Choose NYT Crossplay, Words With Friends, Scrabble US/UK, or all dictionaries, then tap SEARCH. Results are sorted by Scrabble-style score.' },
];

const howToSchema = getHowToSchema(howToSteps);

const faqs = [
  {
    question: 'What is a word scramble?',
    answer: 'A word scramble is a puzzle where the letters of a word are rearranged in a random order. Your goal is to unscramble the letters and identify the original word. Word scrambles appear everywhere — in newspaper puzzles like Jumble, classroom activities, mobile games, and team-building exercises. The challenge ranges from simple 3-letter words to complex 10+ letter words.',
  },
  {
    question: 'How does the word scramble solver work?',
    answer: 'Enter your rack (letters plus up to three wildcards as ? or space). We match words from the dictionary you select that can be spelled using those tiles, then apply your optional filters (starts with, ends with, contains, exact length, include/exclude letters). Matches are ranked by a Scrabble-style letter score for quick scanning.',
  },
  {
    question: 'What games use word scrambles?',
    answer: 'Word scrambles appear in many games: <a href="/jumble-solver" class="text-primary hover:underline">Jumble</a> (newspaper puzzle), <a href="/scrabble" class="text-primary hover:underline">Scrabble</a> (rack management), <a href="/text-twist" class="text-primary hover:underline">Text Twist</a> (letter jumbles), <a href="/word-cookies" class="text-primary hover:underline">Word Cookies</a>, and many more. Our solver works for any scrambled letter set from any source.',
  },
  {
    question: 'What are the best strategies for solving word scrambles manually?',
    answer: '1. <strong class="text-foreground">Look for common patterns first</strong> — Vowel-consonant-vowel (VCV) patterns like "ara", "ele", "ini" often appear. 2. <strong class="text-foreground">Try common prefixes and suffixes</strong> — Words starting with UN-, RE-, IN-, DIS-, PRE- and ending with -ING, -ED, -ER, -LY, -TION are extremely common. 3. <strong class="text-foreground">Start with rare letters</strong> — Q, Z, X, J, and V are the rarest in English. Finding where they go often narrows the answer quickly. 4. <strong class="text-foreground">Look for doubled letters</strong> — LL, EE, SS, OO in the scrambled set often mean doubled letters in the answer.',
  },
  {
    question: 'What are common 2-letter and 3-letter words to look for?',
    answer: 'Common 2-letter words: <strong class="text-foreground">AA, AI, AN, AR, AS, AT, BE, BY, DO, GO, HE, HI, IF, IN, IS, IT, ME, MY, NO, OF, ON, OR, OX, QI, SO, TO, UP, US, WE, XI, XU, ZA, ZO</strong>. Common 3-letter words: <strong class="text-foreground">THE, AND, FOR, ARE, BUT, NOT, YOU, ALL, ANY, CAN, HAD, HER, WAS, ONE, OUR, OUT, PER, SET, SUN, TOP, TRY</strong>. These small words are often the building blocks for longer scrambled words.',
  },
  {
    question: 'Is the word scramble solver free?',
    answer: 'Yes! Our word scramble solver is completely free to use with no sign-up, no download, and no limits. Use it as many times as you want on any device.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta} fullBleed={true}>
<div class="tool-page-skin">
<section class="tool-hero" style="--wst-search-btn-bg: #f2c051; --wst-search-btn-shadow: #c9a035;">
<div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Word Scramble - Word Finder</h1>
  <p class="page-body">Enter up to 3 wildcards (? or space). Filter by starts, ends, contains, and length — then search across game dictionaries.</p>

  <WordsStartWithTool client:load />
</div>
</section>

<div class="tool-content">
<AdSense />

<div class="page-wrapper">
  <h2 class="page-h2">What is Word Scramble?</h2>
  <div class="page-body">
    <p>Word scramble is a classic puzzle format where letters are presented in a jumbled, random order and the solver must rearrange them to form meaningful words. It's one of the most common puzzle types in newspapers (where it appears as the famous <a href="/jumble-solver" class="text-primary hover:underline">Jumble puzzle</a>), classrooms, party games, and mobile apps.</p>
    <p>Unlike an anagram (which typically rearranges one known word into another), a word scramble presents you with letters that could form <em>multiple</em> words — or a single word that you have to figure out. The challenge scales with difficulty: easy scrambles might hide simple words like "CAT" → "ACT", while hard ones might hide complex words like "STABLE" → "ABLES T" (no, wait — try <strong class="text-foreground">TABLES</strong>, <strong class="text-foreground">BLASTED</strong>, etc.).</p>
    <p>Our word scramble solver handles any letter combination, no matter how scrambled. Whether you've got a 3-letter puzzle or a 12-letter challenge, our tool reveals every valid word instantly.</p>
  </div>

  <h2 class="page-h2">How to Use the Word Scramble Solver</h2>
  <div class="page-tool-card">
    <div class="space-y-5">
      {howToSteps.map((step, i) => (
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">{i + 1}</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">{step.name}</h3>
            <p class="text-sm text-muted-foreground">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <h2 class="page-h2">How to Solve Word Scrambles Without a Tool</h2>
  <div class="page-body">
    <p>Looking for common letter patterns: Vowel-consonant-vowel (VCV) patterns like A-E, I-O, U-A appear constantly. Common pairs: TH, HE, IN, ER, AN, RE, ON, AT, ST, and ND. Scan your scrambled letters for these patterns first.</p>
    <p>Try common prefixes: UN-, RE-, IN-, OUT-, DIS-, PRE-, PRO- are common English prefixes. If your scramble starts with these patterns, the word might begin with one of them.</p>
    <p>Look for suffixes: Common endings like -ING, -ED, -ER, -LY, -TION, -NESS, -MENT, -ABLE, -IBLE often unlock scrambles quickly. If your letters end in G-N-I, try -ING.</p>
    <p>Start with rare letters: Q, Z, X, J, and V are the rarest in English. If your scramble has a Q, look for QI or QAT. A Z often pairs with A, O, or E. Finding the rare letter's position narrows the answer dramatically.</p>
    <p>Watch for doubled letters: If your scramble has two identical letters (SS, TT, LL, EE, etc.), they're likely doubled in the original word. In a scramble like "LATTE", the doubled TT points toward "LETTA" → "TABLET".</p>
  </div>

  <h2 class="page-h2">Real Word Scramble Examples</h2>
  <div class="page-body">
    <p>Here are some real word scramble puzzles and what our solver finds:</p>
  </div>
  <div class="page-tool-card">
    <div class="space-y-3">
      {[
        { scrambled: 'ELST', answer: 'LETS', note: 'Also: ELTS, ELST (archaic), SETL (dialectal)' },
        { scrambled: 'NIPCE', answer: 'PENIC', note: 'Also: PIECE (6 letters), PINE C (7+), INCEP (archaic)' },
        { scrambled: 'RTAWE', answer: 'WATER', note: 'Also: TARWE, WARE T, RETAW (backward)' },
        { scrambled: 'NIACL', answer: 'LANCI', note: 'Also: LINAC, CANIL — CLAIN (archaic), CARLIN (7 letters)' },
      ].map(({ scrambled, answer, note }) => (
        <div class="p-4 rounded-xl border border-border bg-muted/20">
          <div class="flex items-center gap-3 mb-2">
            <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Scrambled</span>
            <code class="font-mono font-bold text-foreground text-lg tracking-widest">{scrambled}</code>
          </div>
          <div class="text-sm">
            <span class="text-muted-foreground">Finds words like: </span>
            <span class="font-semibold text-primary">{answer}</span>
            <span class="text-xs text-muted-foreground ml-2">({note})</span>
          </div>
        </div>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Related Word Tools</h2>
  <div class="page-body">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: 'Jumble Solver', href: '/jumble-solver', icon: '📰' },
        { name: 'Descrambler', href: '/descrambler', icon: '🔀' },
        { name: 'Anagram Solver', href: '/anagram-solver', icon: '📚' },
        { name: 'Word Finder', href: '/word-finder', icon: '🔍' },
      ].map((tool) => (
        <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-background hover:border-primary/50 hover:shadow-sm transition-all group">
          <span class="text-xl">{tool.icon}</span>
          <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
        </a>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]" set:html={faq.question} />
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>
</div>
</div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
</Layout>
