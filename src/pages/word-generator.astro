---
import Layout from '@/layouts/Layout.astro';
import AdSense from '@/components/AdSense';
import RandomWordGenerator from '@/components/RandomWordGenerator';
import InternalLinks from '@/components/InternalLinks.astro';
import SeoSchemaBlocks from '@/components/SeoSchemaBlocks.astro';
import { getMeta } from '@/lib/meta';

const meta = getMeta(
  '/word-generator',
  'Word Generator - Random Word Generator | Free Tool',
  'Free word generator: get random interesting words for creative writing, games, vocabulary building, or just learning new words. Filter by length or browse alphabetically.'
);

const faqs = [
  {
    question: 'What is a word generator?',
    answer: 'A word generator is a tool that helps you discover new and interesting words. Unlike a word unscrambler where you input letters to find words, a word generator displays curated or random words for inspiration, learning, or fun. You can filter by word length, browse alphabetically, or just hit "generate" to discover something new.',
  },
  {
    question: 'What can I use the word generator for?',
    answer: 'The word generator has many uses: <strong class="text-foreground">Creative writing</strong> — find the perfect word for your story or poem. <strong class="text-foreground">Vocabulary building</strong> — discover new words and add them to your vocabulary. <strong class="text-foreground">Word games</strong> — get inspiration for Scrabble, Words With Friends, or any word challenge. <strong class="text-foreground">Naming</strong> — find unique words for project names, business names, or usernames. <strong class="text-foreground">Crosswords</strong> — look for unusual words that might fit tricky clues.',
  },
  {
    question: 'Can I filter words by length?',
    answer: 'Yes! The word generator lets you filter by minimum and maximum word length, so you can find exactly the right word for your needs — a short punchy word for a headline, or a longer vocabulary word for academic writing.',
  },
  {
    question: 'Is the word generator free?',
    answer: 'Yes! Our word generator is completely free to use with no sign-up, no download, and no limits. Generate as many words as you want.',
  },
];

const interestingWords = [
  { word: 'Ephemeral', meaning: 'Lasting for a very short time' },
  { word: 'Serendipity', meaning: 'Finding something good without looking for it' },
  { word: 'Petrichor', meaning: 'The smell of rain on dry earth' },
  { word: 'Mellifluous', meaning: 'Sweet-sounding; pleasant to hear' },
  { word: 'Ineffable', meaning: 'Too great to be expressed in words' },
  { word: 'Luminous', meaning: 'Full of or shedding light; bright' },
  { word: 'Eloquent', meaning: 'Fluent or persuasive in speaking or writing' },
  { word: 'Ubiquitous', meaning: 'Present, appearing, or found everywhere' },
  { word: 'Ethereal', meaning: 'Extremely delicate and light; heavenly' },
  { word: 'Resilient', meaning: 'Able to recover quickly from difficulties' },
  { word: 'Quintessential', meaning: 'Representing the most perfect example' },
  { word: 'Sanguine', meaning: 'Optimistic or positive, especially in a difficult situation' },
  { word: 'Cacophony', meaning: 'A harsh, discordant mixture of sounds' },
  { word: 'Surreptitious', meaning: 'Kept secret, especially because it would not be approved' },
  { word: 'Surreal', meaning: 'More like a dream; bizarre' },
  { word: 'Ebullient', meaning: 'Cheerful and full of energy' },
  { word: 'Labyrinthine', meaning: 'Like a labyrinth; winding and complicated' },
  { word: 'Nebulous', meaning: 'Unclear, vague, or ill-defined' },
  { word: 'Obfuscate', meaning: 'To make obscure, unclear, or unintelligible' },
  { word: 'Perspicacious', meaning: 'Having a ready insight into things; shrewd' },
  { word: 'Ameliorate', meaning: 'To make something bad better' },
  { word: 'Beguile', meaning: 'To charm or enchant, sometimes deceptively' },
  { word: 'Cogent', meaning: 'Clear, logical, and convincing' },
  { word: 'Desultory', meaning: 'Lacking a plan, purpose, or enthusiasm' },
  { word: 'Fastidious', meaning: 'Very attentive to accuracy and detail' },
  { word: 'Garrulous', meaning: 'Excessively talkative' },
  { word: 'Hackneyed', meaning: 'Lacking originality through overuse' },
  { word: 'Insidious', meaning: 'Proceeding in a subtle way but with harmful effects' },
  { word: 'Juxtaposition', meaning: 'Placing two things close together for contrast' },
];
---

<Layout meta={meta} fullBleed={true}>
  <div class="tool-page-skin">
    <section class="tool-hero">
      <div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Word Generator</h1>
        <p class="page-body">
          Browse curated interesting words or generate random words instantly for writing, games, and vocabulary practice.
        </p>
        <div class="page-tool-card">
          <RandomWordGenerator client:load />
        </div>
      </div>
    </section>

    <div class="tool-content">
      <AdSense />
      <div class="page-wrapper">
        <section class="mt-2 p-6 rounded-lg border border-border bg-card">
    <h2 class="text-2xl font-bold mb-4 text-foreground">Interesting Words to Know</h2>
    <p class="text-muted-foreground text-[15px] leading-relaxed mb-6">
      Sometimes the best words are the ones you don\'t hear every day. Here\'s a curated collection of interesting English words — perfect for expanding your vocabulary, creative writing, word games, or just impressing your friends.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
      {interestingWords.map(({ word, meaning }) => (
        <div class="p-4 rounded-lg border border-border bg-background hover:bg-muted/50 transition-colors">
          <span class="text-lg font-semibold text-foreground">{word}</span>
          <p class="text-sm text-muted-foreground mt-1">{meaning}</p>
        </div>
      ))}
    </div>
        </section>

        <section class="mt-8 p-6 rounded-lg border border-border bg-card">
    <h2 class="text-2xl font-bold mb-4 text-foreground">What is a Word Generator?</h2>
    <div class="space-y-4 text-muted-foreground text-[15px] leading-relaxed">
      <p>
        A word generator is a tool that helps you discover new words. Unlike a word unscrambler where you input letters to find words, a word generator displays a curated list of interesting words for inspiration, learning, or fun.
      </p>
      <p>
        Word generators are useful for:
      </p>
      <ul class="list-disc pl-6 space-y-2">
        <li><strong class="text-foreground">Creative writing</strong> — Find the perfect word for your story, poem, or song.</li>
        <li><strong class="text-foreground">Vocabulary building</strong> — Discover new words to expand your English vocabulary.</li>
        <li><strong class="text-foreground">Word games</strong> — Get inspired for games like Pictionary, charades, or vocabulary challenges.</li>
        <li><strong class="text-foreground">Names and branding</strong> — Find unique words for project names, business names, or usernames.</li>
        <li><strong class="text-foreground">Crossword puzzles</strong> — Look for unusual words that might fit tricky clues.</li>
      </ul>
    </div>
        </section>

        <!-- More Tools -->
        <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-xl font-bold mb-4 text-foreground">More Word Tools to Try</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { name: 'Word Unscrambler', href: '/word-unscrambler', icon: '🔤' },
          { name: 'Anagram Solver', href: '/anagram-solver', icon: '📚' },
          { name: 'Word Finder', href: '/word-finder', icon: '🔍' },
          { name: 'Scrabble Go', href: '/scrabble-go', icon: '🎲' },
        ].map((tool) => (
          <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-background hover:border-primary/50 hover:shadow-sm transition-all group">
            <span class="text-xl">{tool.icon}</span>
            <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
          </a>
        ))}
      </div>
    </div>
        </section>

        <!-- FAQ -->
        <section class="mt-8 max-w-3xl mx-auto" id="faq">
    <h2 class="page-h2">Frequently Asked Questions</h2>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="faq-details">
          <summary class="faq-summary">
            <span class="font-semibold text-foreground text-[15px]" set:html={faq.question} />
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-body">
            <p set:html={faq.answer} />
          </div>
        </details>
      ))}
    </div>
        </section>

        <InternalLinks />

        <div class="mt-12"></div>
      </div>
    </div>
  </div>

  <SeoSchemaBlocks faqs={faqs} />
</Layout>
