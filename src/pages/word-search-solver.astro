---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema, getHowToSchema } from '@/lib/schema';

const meta = getMeta(
  '/word-search-solver',
  'Word Search Solver - Find Hidden Words | Free Tool',
  'Free word search solver: enter your puzzle letters to find every valid word hidden in the grid. Solve word search puzzles faster with our instant tool.'
);

const howToSteps = [
  { name: 'Gather your letters', text: 'Enter the letters from your word search grid. For simple unscrambling, just type the letters you want to find words from.' },
  { name: 'Find all valid words', text: 'Our solver shows every valid English word from your letters, sorted by length.' },
  { name: 'Match to your puzzle', text: 'Use the found words to locate them in your word search grid â??horizontally, vertically, or diagonally.' },
];

const howToSchema = getHowToSchema(howToSteps);

const faqs = [
  {
    question: 'What is a word search puzzle?',
    answer: 'A word search (also called "Word Find" or "Search-a-Word") is a puzzle where letters are arranged in a grid, with a list of words hidden within. The words can be placed horizontally (left-to-right or right-to-left), vertically (top-to-bottom or bottom-to-top), or diagonally (any of the four diagonal directions). Players must find all the hidden words from the list.',
  },
  {
    question: 'How does the word search solver work?',
    answer: 'Our solver takes the letters from your word search grid (or a specific set of letters) and finds every valid English word that can be formed from them. While it can\'t directly map words onto a 2D grid, it\'s perfect for unscrambling letters to find hidden words. If you\'re stuck on a specific word from your list, enter the letters and see if it\'s a valid English word â??and what other words are hiding in those same letters.',
  },
  {
    question: 'What directions can words go in a word search?',
    answer: 'Traditional word search puzzles allow words in 8 directions: left-to-right, right-to-left, top-to-bottom, bottom-to-top, and the four diagonals (top-left to bottom-right, bottom-right to top-left, top-right to bottom-left, bottom-left to top-right). Some themed or advanced word searches may add additional rules (like word Jumbles where letters overlap).',
  },
  {
    question: 'What are some tips for solving word searches faster?',
    answer: '1. <strong class="text-foreground">Start with unique letters:</strong> Words containing Q, Z, X, or J are usually easier to spot first because those letters appear rarely. 2. <strong class="text-foreground">Use the word list:</strong> Look at each word and mentally scan the grid for its first and last letters â??this narrows your search significantly. 3. <strong class="text-foreground">Circle words as you find them:</strong> This prevents re-scanning and helps you see remaining letter patterns. 4. <strong class="text-foreground">Check the leftover letters:</strong> After finding all listed words, the remaining letters in themed puzzles often spell a bonus word or phrase.',
  },
  {
    question: 'Can I use this for themed word searches?',
    answer: 'Absolutely. Themed word searches (like "Animals" or "Summer") have word lists that all relate to a topic. Our solver finds every valid word from your letters, so if you\'re stuck on a themed word like "CROCODILE" from letters "OCCDRILAE", our tool instantly confirms it and shows other words hiding in those letters.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta} fullBleed={true}>
  <div class="tool-page-skin">
    <section class="tool-hero">
      <div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Word Search Solver</h1>
        <p class="page-body">
          Enter your word search letters and find every valid word hidden within them. Solve any word search puzzle faster.
        </p>
        <div class="page-tool-card">
          <UnscrambleTool client:load />
        </div>
      </div>
    </section>

    <div class="tool-content">
      <AdSense />
      <div class="page-wrapper">

  <!-- What is a Word Search -->
  <section class="mt-12 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-4 text-foreground">What is a Word Search Puzzle?</h2>
      <div class="text-[15px] text-muted-foreground leading-relaxed space-y-4">
        <p>
          A word search puzzle (also known as <em>Word Find</em>, <em>Search-a-Word</em>, or <em>Mystery Word</em>) is a classic puzzle found in newspapers, puzzle books, and mobile apps worldwide. The puzzle consists of a grid of letters and a list of words to find. Words are hidden in the grid in straight lines â??horizontally, vertically, or diagonally â??and can read forwards or backwards.
        </p>
        <p>
          The challenge is finding all the hidden words as quickly as possible. While word searches are typically a relaxing, no-pressure puzzle, competitive players enjoy racing to complete them as fast as possible. Our solver helps you find the words you\'re stuck on, making it easier to finish any puzzle.
        </p>
      </div>
    </div>
  </section>

  <!-- How to Solve -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-6 text-foreground">How to Solve Word Search Puzzles Faster</h2>
      <div class="space-y-5">
        {[
          { num: '1', title: 'Scan for unique letters first', desc: 'Words containing Q, Z, X, J, or other rare letters are easiest to spot because there are few of them in the grid. Start with those to quickly eliminate easy words from your list.' },
          { num: '2', title: 'Use the word list strategically', desc: 'Look at a word on your list and mentally scan for its first and last letters in the grid. When you find them, check all 8 directions between those points â??this is much faster than blind scanning.' },
          { num: '3', title: 'Circle as you go', desc: 'Circle each word as you find it. This prevents re-scanning the same area and helps you see which parts of the grid still have unclaimed letters â??which often contain the remaining words.' },
          { num: '4', title: 'Check the leftover letters', desc: 'After finding all listed words in a themed puzzle, the remaining un-circled letters often spell a bonus word or phrase (like a hidden message). This is a common feature in published word searches.' },
          { num: '5', title: 'Use our solver when stuck', desc: 'If you\'re stuck on a specific word, enter its letters in our solver. It confirms whether it\'s a valid English word and shows other words hiding in those same letters â??helping you see patterns you might have missed.' },
        ].map(({ num, title, desc }) => (
          <div class="flex gap-4">
            <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">{num}</div>
            <div>
              <h3 class="font-semibold text-foreground mb-1">{title}</h3>
              <p class="text-sm text-muted-foreground">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Word Search Directions -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-4 text-foreground">ð??� Word Search: All 8 Directions</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm text-muted-foreground">
        {['â??Left to Right', 'â??Right to Left', 'â??Top to Bottom', 'â??Bottom to Top', 'â??Top-left to Bot-right', 'â??Top-right to Bot-left', 'â??Bot-left to Top-right', 'â??Bot-right to Top-left'].map((dir) => (
          <div class="p-3 rounded-lg border border-border bg-background text-center font-medium text-foreground">
            {dir}
          </div>
        ))}
      </div>
      <p class="text-xs text-muted-foreground mt-4">
        Some advanced word search variants also allow words that wrap around the edges, or words that share letters (like in a crossword). Check your puzzle\'s rules if you\'re not finding a word in any of the 8 standard directions.
      </p>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-xl font-bold mb-4 text-foreground">More Word Game Tools</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {[
          { name: 'Word Finder', href: '/word-finder', icon: 'ð??�' },
          { name: 'Boggle Solver', href: '/boggle-solver', icon: 'ð??²' },
          { name: 'Word Scramble Solver', href: '/word-scramble', icon: '??' },
          { name: 'Text Twist', href: '/text-twist', icon: 'ð???' },
        ].map((tool) => (
          <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-background hover:border-primary/50 hover:shadow-sm transition-all group">
            <span class="text-xl">{tool.icon}</span>
            <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mt-8 max-w-3xl mx-auto" id="faq">
    <h2 class="page-h2">Frequently Asked Questions</h2>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="faq-details">
          <summary class="faq-summary">
            <span class="font-semibold text-foreground text-[15px]" set:html={faq.question} />
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-body">
            <p set:html={faq.answer} />
          </div>
        </details>
      ))}
    </div>
  </section>

  <div class="mt-12"></div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
</Layout>
