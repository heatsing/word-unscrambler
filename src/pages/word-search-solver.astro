---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema } from '@/lib/schema';

const meta = getMeta(
  '/word-search-solver',
  'Word Search Solver - Find Hidden Words',
  'Word search solver: enter your word search puzzle letters to find hidden words. Great for solving word search puzzles faster.'
);

const faqs = [
  {
    question: 'How does the word search solver work?',
    answer: 'Our word search solver has two uses: First, enter the letters from your puzzle grid to find words hidden within them. Second, if you have a specific word to find, you can enter its letters to verify it\'s valid or check if it can be made from a set of letters.',
  },
  {
    question: 'What is a word search puzzle?',
    answer: 'A word search (also called word find or search-a-word) is a puzzle where letters are arranged in a grid and words are hidden horizontally, vertically, or diagonally. Players must find all the hidden words listed.',
  },
  {
    question: 'Can the solver find words going in any direction?',
    answer: 'The UnscrambleTool helps you find words from a set of letters. For a full word search solver that maps words onto a 2D grid, you would need to manually input your grid. Our tool is most useful for checking if specific words can be made from your available letters.',
  },
  {
    question: 'Can I use the word search solver on any word search puzzle?',
    answer: 'Yes! Our solver works with any word search puzzle regardless of the theme, size, or difficulty. Just enter the letters you\'re working with and find valid words.',
  },
  {
    question: 'Is the word search solver free?',
    answer: 'Yes, our word search solver is completely free to use with no sign-up required.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta}>
  <header class="text-center mb-8">
    <h1 class="text-4xl font-bold mb-4 text-foreground">Word Search Solver</h1>
    <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
      Enter your word search letters to find every valid word hidden within them.
    </p>
  </header>

  <UnscrambleTool client:load />

  <AdSense />

  <section class="mt-12 p-6 rounded-lg border border-border bg-card">
    <h2 class="text-2xl font-bold mb-4 text-foreground">How to Solve Word Search Puzzles</h2>
    <div class="space-y-4 text-muted-foreground text-[15px] leading-relaxed">
      <p>
        Word search puzzles are a beloved classic — grids filled with seemingly random letters hiding a list of themed words. Whether you\'re working through a newspaper puzzle or a themed word search, our solver helps you find the words you\'re looking for.
      </p>

      <h3 class="text-lg font-semibold mt-4 mb-2 text-foreground">Word Search Tips & Tricks</h3>
      <ul class="list-disc pl-6 space-y-2">
        <li><strong class="text-foreground">Scan in patterns</strong> — Don\'t just scan left-to-right. Words can be horizontal (left-to-right or right-to-left), vertical (top-to-bottom or bottom-to-top), or diagonal (any direction).</li>
        <li><strong class="text-foreground">Circle the obvious words first</strong> — Find the easy words on your list first, then focus on the remaining letters for harder words.</li>
        <li><strong class="text-foreground">Look for unique letter combinations</strong> — Words with Q, Z, X, or J are easier to spot because of their rarity. Start with those.</li>
        <li><strong class="text-foreground">Use the leftover letters</strong> — After finding all the listed words, the remaining letters in a themed word search often spell out a bonus word or phrase.</li>
        <li><strong class="text-foreground">Try the "word list" approach</strong> — Look at each word on your list and mentally search for its first letter in the grid, then scan in all directions from there.</li>
      </ul>

      <h3 class="text-lg font-semibold mt-4 mb-2 text-foreground">How Word Searches Work</h3>
      <p>
        In a traditional word search, words are placed in a grid in straight lines — horizontally, vertically, or diagonally. Words can read forwards or backwards. The remaining letters fill the empty spaces. The challenge is finding all the hidden words within the jumble of letters.
      </p>
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-bold mb-4 text-foreground">Frequently Asked Questions</h2>
    <dl class="space-y-4 text-sm">
      {faqs.map((faq) => (
        <div class="rounded-lg border border-border bg-card p-4">
          <dt class="font-semibold text-foreground">{faq.question}</dt>
          <dd class="text-muted-foreground mt-2 leading-relaxed">{faq.answer}</dd>
        </div>
      ))}
    </dl>
  </section>

  <div class="mt-8 flex flex-wrap gap-3 text-sm">
    <a href="/word-finder" class="btn btn-primary">Word Finder</a>
    <a href="/boggle-solver" class="btn btn-primary">Boggle Solver</a>
    <a href="/word-scramble" class="btn btn-primary">Word Scramble</a>
    <a href="/text-twist" class="btn btn-primary">Text Twist</a>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
