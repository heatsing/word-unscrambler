---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import AdSense from '@/components/AdSense';
import InternalLinks from '@/components/InternalLinks.astro';
import SeoSchemaBlocks from '@/components/SeoSchemaBlocks.astro';
import { getMeta } from '@/lib/meta';

const meta = getMeta(
  '/scrabble-go',
  'Scrabble Go Cheat - Find Highest Scoring Words | Free Tool',
  'Free Scrabble Go cheat: enter your tiles and find every valid word sorted by score. Get the highest-scoring plays and dominate your opponents.'
);

const howToSteps = [
  { name: 'Enter your tiles', text: 'Type all the letters from your Scrabble Go rack into the search box.' },
  { name: 'Find all valid words', text: 'Results are sorted by Scrabble score automatically. The highest-scoring words appear at the top.' },
  { name: 'Look for Bingos', text: 'Watch for 7-letter words — using all 7 tiles earns a 50-point Bingo bonus.' },
  { name: 'Check premium squares', text: 'When placing words on the board, aim for Triple Word (TW) and Double Word (DW) squares to maximize your score.' },
];

const faqs = [
  {
    question: 'What is Scrabble Go and how is it different from classic Scrabble?',
    answer: 'Scrabble Go is the official mobile version of Scrabble, developed by Scopely and released in 2020. While the core gameplay (forming words on a 15×15 grid with tile values and premium squares) is the same as classic Scrabble, Scrabble Go adds social features, daily challenges, tournaments, and a league/ranking system.',
  },
  {
    question: 'How does the Scrabble Go cheat tool work?',
    answer: 'Enter the letters from your Scrabble Go rack and our solver finds every valid English word you can make from those letters, sorted by point value. The highest-scoring words appear at the top.',
  },
  {
    question: 'Does the Scrabble Go cheat work for the daily challenges?',
    answer: 'Yes. Scrabble Go\'s daily challenges often have specific rules or letter distributions. Our cheat works with any letter set, so you can use it for daily challenges, tournaments, or any game mode.',
  },
  {
    question: 'What are the best Scrabble Go opening words?',
    answer: 'The best Scrabble Go opening words maximize vowel-consonant balance. Strong openers include <strong class="text-foreground">ADIEU</strong> (4 vowels, 5 letters), <strong class="text-foreground">AUDIO</strong>, <strong class="text-foreground">RAISE</strong>, <strong class="text-foreground">STARE</strong>, and <strong class="text-foreground">SOVRAN</strong>.',
  },
  {
    question: 'How do I get the Bingo bonus in Scrabble Go?',
    answer: 'Playing all 7 tiles in a single word earns a 50-point Bingo bonus — identical to classic Scrabble. To find Bingo candidates, run your full 7-tile rack through our solver and look for any 7-letter word.',
  },
  {
    question: 'Is using a Scrabble Go cheat considered cheating?',
    answer: 'Not at all. A word finder is a vocabulary tool — it shows you words that are already in the dictionary. Think of it like using a dictionary when you\'re unsure of a spelling. Our tool helps you learn new words (every unfamiliar word is a vocabulary lesson), find plays you\'d never have spotted otherwise, and improve your overall word skills.',
  },
];

const TILE_VALUES = [
  { letters: 'A, E, I, O, U, L, N, S, T, R', value: 1 },
  { letters: 'D, G', value: 2 },
  { letters: 'B, C, M, P', value: 3 },
  { letters: 'F, H, V, W, Y', value: 4 },
  { letters: 'K', value: 5 },
  { letters: 'J, X', value: 8 },
  { letters: 'Q, Z', value: 10 },
];
---

<Layout meta={meta} fullBleed={true}>
<div class="tool-page-skin">
<section class="tool-hero">
<div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Scrabble Go Cheat</h1>
  <p class="page-body">Enter your Scrabble Go tiles and find every valid word, sorted by score. Get the highest-scoring play every turn.</p>

  <div class="page-tool-card">
    <UnscrambleTool client:load />
  </div>
</div>
</section>

<div class="tool-content">
<AdSense />

<div class="page-wrapper">
  <h2 class="page-h2">What is Scrabble Go?</h2>
  <div class="page-body">
    <p><a href="https://scrabblego.hasbro.com/" target="_blank" rel="noopener" class="text-primary hover:underline font-medium">Scrabble Go</a> is the official mobile adaptation of the classic Scrabble board game, developed by Scopely in partnership with Hasbro. Launched in 2020, it quickly became one of the most popular mobile word games.</p>
    <p>The core gameplay mirrors classic Scrabble: form words on a 15×15 grid, each letter has a point value, and premium squares (double/triple letter and word) multiply scores. Where Scrabble Go differs is in its social and competitive features — league rankings, tournaments, daily challenges, collectible trophies, and a progression system.</p>
    <p>Our Scrabble Go cheat tool works with any letter set from the game, helping you find the highest-scoring plays.</p>
  </div>

  <h2 class="page-h2">Scrabble Go Tile Values</h2>
  <div class="page-body">
    <p>Scrabble Go uses the same tile values as classic Scrabble. Here's the reference:</p>
  </div>
  <div class="page-tool-card">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left py-2 px-3 font-semibold text-foreground">Points</th>
            <th class="text-left py-2 px-3 font-semibold text-foreground">Letters</th>
          </tr>
        </thead>
        <tbody>
          {TILE_VALUES.map((row, i) => (
            <tr key={i} class={i % 2 === 0 ? 'bg-muted/30' : ''}>
              <td class="py-2 px-3 font-bold text-foreground">{row.value}</td>
              <td class="py-2 px-3 text-muted-foreground font-mono tracking-wider">{row.letters}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <h2 class="page-h2">How to Use the Scrabble Go Solver</h2>
  <div class="page-tool-card">
    <div class="space-y-5">
      {howToSteps.map((step, i) => (
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">{i + 1}</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">{step.name}</h3>
            <p class="text-sm text-muted-foreground">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Scrabble Go Strategy Tips</h2>
  <div class="page-body">
    <p><strong>1. Hunt for Bingos every turn:</strong> Using all 7 tiles in one play earns a 50-point Bingo bonus. Every time you get a full rack, run it through our solver and look for 7-letter words.</p>
    <p><strong>2. Master high-value 2-letter words:</strong> Words like <strong class="text-foreground">QI</strong>, <strong class="text-foreground">XI</strong>, <strong class="text-foreground">ZA</strong>, <strong class="text-foreground">JO</strong>, <strong class="text-foreground">XU</strong>, and <strong class="text-foreground">ZO</strong> let you play a single tile on a premium square.</p>
    <p><strong>3. Save high-value tiles for premium squares:</strong> Q (10 pts), Z (10 pts), X (8 pts), and J (8 pts) should almost never be played on neutral spaces.</p>
    <p><strong>4. Use parallel plays to score twice:</strong> When you place a word perpendicular to an existing word, every intersecting tile creates a new word in the perpendicular direction.</p>
    <p><strong>5. Watch your vowel-consonant balance:</strong> Aim for 3-4 vowels and 3-4 consonants in a 7-tile rack.</p>
  </div>

  <h2 class="page-h2">Related Word Game Tools</h2>
  <div class="page-body">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: 'Scrabble (Classic)', href: '/scrabble', icon: '🎲' },
        { name: 'Words With Friends', href: '/words-with-friends', icon: '📱' },
        { name: 'Wordfeud', href: '/wordfeud', icon: '🎮' },
        { name: 'Word Unscrambler', href: '/word-unscrambler', icon: '🔤' },
      ].map((tool) => (
        <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-background hover:border-primary/50 hover:shadow-sm transition-all group">
          <span class="text-xl">{tool.icon}</span>
          <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
        </a>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]" set:html={faq.question} />
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>
  <InternalLinks />
</div>
</div>
</div>
<SeoSchemaBlocks faqs={faqs} howToSteps={howToSteps} />
</Layout>
