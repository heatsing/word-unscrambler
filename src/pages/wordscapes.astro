---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import AdSense from '@/components/AdSense';
import { getMeta } from '@/lib/meta';
import { getFAQPageSchema, getHowToSchema } from '@/lib/schema';

const meta = getMeta(
  '/wordscapes',
  'Wordscapes Solver - Find All Words | Free Cheat Tool',
  'Free Wordscapes solver: enter your letter tray to find every valid word. Complete any Wordscapes level with our instant solver. Works on all devices.'
);

const howToSteps = [
  { name: 'Enter your letter tray', text: 'Type all the letters shown at the bottom of your Wordscapes screen — these are the letters available for that level.' },
  { name: 'Filter by word length (optional)', text: 'Look at the crossword grid and note how many letters each missing word needs. Set Min and Max length to match.' },
  { name: 'Find all valid words', text: 'Our solver shows every valid word from your letters, sorted by length. Find the hidden bonus word (usually the longest one) for extra coins.' },
  { name: 'Complete the level', text: 'Fill in the crossword grid with the words you find. Each correct word fills in the corresponding blanks.' },
];

const howToSchema = getHowToSchema(howToSteps);

const faqs = [
  {
    question: 'What is Wordscapes and how does it work?',
    answer: 'Wordscapes is a popular mobile word puzzle game developed by PeopleFun that combines crossword-style grid filling with swipe-to-spell mechanics. Each level presents a crossword-style grid with blank spaces and a set of letters at the bottom. Your goal is to fill every blank by forming words from those letters.',
  },
  {
    question: 'What\'s the trick to solving hard Wordscapes levels?',
    answer: 'Hard Wordscapes levels typically have two characteristics: (1) long words with uncommon letter combinations, and (2) bonus words that are hard to spot. The key strategy: look at the crossword grid first — it tells you exactly how many letters each word needs. Then focus on finding the longest word first (usually the bonus word).',
  },
  {
    question: 'How do bonus words work in Wordscapes?',
    answer: 'Each Wordscapes level has at least one "bonus word" — an extra word hidden in the letter tray that isn\'t required to complete the level but awards bonus coins. Bonus words are typically the longest words available from the letter set.',
  },
  {
    question: 'How many levels are in Wordscapes?',
    answer: 'Wordscapes has expanded significantly since its launch. The game now has over 6,000 levels across multiple packs including the Main series, Travel (themed by country), Tribe (themed by profession), and seasonal events. Our solver works with any letter set.',
  },
  {
    question: 'Does the Wordscapes solver work for Wordscapes 2 and other versions?',
    answer: 'Yes. Our solver works with any letter combination, so it covers Wordscapes, Wordscapes 2, and any other variant. Just enter the letters from your current level\'s tray.',
  },
  {
    question: 'Can I use the Wordscapes solver for free?',
    answer: 'Yes! Our Wordscapes solver is completely free to use with no sign-up, no download, and no limits.',
  },
];

const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta} fullBleed={true}>
<div class="tool-page-skin">
<section class="tool-hero">
<div class="tool-hero-inner page-wrapper">
  <div class="breadcrumb">
    <a href="/">Home</a> <span>›</span> <a href="/">Tools</a> <span>›</span> <span class="current">Wordscapes Solver</span>
  </div>

  <h1 class="page-h1">Wordscapes Solver</h1>
  <p class="page-body">Enter your Wordscapes letter tray and find every valid word. Complete any level instantly — including the hidden bonus word.</p>

  <div class="page-tool-card">
    <UnscrambleTool client:load />
  </div>
</div>
</section>

<div class="tool-content">
<AdSense />

<div class="page-wrapper">
  <h2 class="page-h2">What is Wordscapes?</h2>
  <div class="page-body">
    <p><a href="https://play.google.com/store/apps/details?id=com.peoplefun.wordscapes" target="_blank" rel="noopener" class="text-primary hover:underline font-medium">Wordscapes</a> is one of the most popular word puzzle games on mobile, with millions of active players. Developed by PeopleFun, the game combines the satisfaction of solving crossword puzzles with the casual swipe mechanics of games like Word Cookies.</p>
    <p>Each level presents a crossword grid with blanks, and a set of letters at the bottom — your job is to fill every blank by forming valid English words from those letters. Levels are organized into themed worlds (Plains, Forest, Desert, Tundra, etc.) with beautiful background imagery.</p>
    <p>Our Wordscapes solver gives you every valid word from your letter tray, so you can breeze through any level.</p>
  </div>

  <h2 class="page-h2">How to Solve Wordscapes Levels</h2>
  <div class="page-tool-card">
    <div class="space-y-5">
      {howToSteps.map((step, i) => (
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">{i + 1}</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">{step.name}</h3>
            <p class="text-sm text-muted-foreground">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Wordscapes Tips & Tricks</h2>
  <div class="page-body">
    <p><strong>1. Read the crossword grid first:</strong> The blanks tell you exactly how many letters each answer needs. A 5-letter answer starting with S? Now you know exactly what to look for.</p>
    <p><strong>2. Find the bonus word first:</strong> Bonus words are always the longest valid words from the letter tray. Run the full letter set through our solver and look for the longest result — that's likely your bonus word.</p>
    <p><strong>3. Look for common letter patterns:</strong> Common suffixes like <strong class="text-foreground">-ING</strong>, <strong class="text-foreground">-ED</strong>, <strong class="text-foreground">-ER</strong>, <strong class="text-foreground">-LY</strong>, <strong class="text-foreground">-TION</strong>, and <strong class="text-foreground">-NESS</strong> appear constantly. Similarly, prefixes like <strong class="text-foreground">UN-</strong>, <strong class="text-foreground">RE-</strong>, <strong class="text-foreground">IN-</strong>, <strong class="text-foreground">OUT-</strong>, and <strong class="text-foreground">DIS-</strong> are worth scanning for.</p>
    <p><strong>4. Save coins for hard levels:</strong> Wordscapes gives you coins for completing levels and finding bonus words. Save these coins for the harder levels later in the game.</p>
  </div>

  <h2 class="page-h2">More Word Game Tools</h2>
  <div class="page-body">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: 'Word Cookies', href: '/word-cookies', icon: '🍪' },
        { name: 'Wordfeud', href: '/wordfeud', icon: '🎮' },
        { name: 'Scrabble Go', href: '/scrabble-go', icon: '🎲' },
        { name: 'Text Twist', href: '/text-twist', icon: '🔄' },
      ].map((tool) => (
        <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-background hover:border-primary/50 hover:shadow-sm transition-all group">
          <span class="text-xl">{tool.icon}</span>
          <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
        </a>
      ))}
    </div>
  </div>

  <h2 class="page-h2">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {faqs.map((faq) => (
      <details class="faq-details">
        <summary class="faq-summary">
          <span class="font-semibold text-foreground text-[15px]" set:html={faq.question} />
          <span class="faq-icon">+</span>
        </summary>
        <div class="faq-body">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>
</div>
</div>
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
</Layout>
