---
import Layout from '@/layouts/Layout.astro';
import UnscrambleTool from '@/components/UnscrambleTool';
import { getMeta } from '@/lib/meta';
import { getSoftwareApplicationSchema, getFAQPageSchema } from '@/lib/schema';

const meta = getMeta('/unscramble', 'Unscramble Words', 'Type your jumbled letters and get every valid word. Filter by length, sort by score or A–Z. Works for Wordle, Scrabble, and crosswords.');
const appSchema = getSoftwareApplicationSchema();
const faqs = [
  { question: 'How does the unscramble tool work?', answer: 'Enter your letters in the box. The tool loads a word list by length and finds all valid words that can be formed from your letters. Results are sorted by Scrabble score by default.' },
  { question: 'Can I use wildcards?', answer: 'The basic version uses only the letters you type. For wildcard support (e.g. ? for any letter), use our full Word Unscrambler tool.' },
  { question: 'Is it free?', answer: 'Yes. The unscramble tool is free to use with no sign-up required.' },
];
const faqSchema = getFAQPageSchema(faqs);
---

<Layout meta={meta} fullBleed={true}>
  <div class="tool-page-skin">
    <section class="tool-hero">
      <div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Unscramble Words</h1>
        <p class="page-body">
          Enter your letters below and instantly find all valid words you can make. Supports up to 3 wildcards (? or space).
        </p>
        <div class="page-tool-card">
          <UnscrambleTool client:load />
        </div>
      </div>
    </section>

    <div class="tool-content">
      <div class="page-wrapper">
        <h2 class="page-h2">Why Unscramble Words?</h2>
        <div class="page-body">
          <p>
            Unscrambling improves pattern recognition and vocabulary. Our tool shows every possible word from your letters for
            Wordle, Scrabble, and other word puzzles.
          </p>
          <p>
            For advanced filters, try <a href="/word-unscrambler" class="text-primary hover:underline">Word Unscrambler</a> or
            <a href="/anagram-solver" class="text-primary hover:underline"> Anagram Solver</a>.
          </p>
        </div>

        <h2 class="page-h2">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="faq-details">
              <summary class="faq-summary">
                <span class="font-semibold text-foreground text-[15px]">{faq.question}</span>
                <span class="faq-icon">+</span>
              </summary>
              <div class="faq-body">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
