---
import Layout from '@/layouts/Layout.astro';
import WordleSolver from '@/components/WordleSolver';
import AdSense from '@/components/AdSense';
import InternalLinks from '@/components/InternalLinks.astro';
import SeoSchemaBlocks from '@/components/SeoSchemaBlocks.astro';
import SchemaOrg from '@/components/SchemaOrg.astro';
import { getMeta } from '@/lib/meta';

const meta = getMeta(
  '/wordle-solver',
  'Wordle Solver & Answer Finder | Find Any Wordle Word',
  'Use our free Wordle solver to find answers to any Wordle puzzle. Enter your known letters, included letters, and excluded letters to instantly find the solution.'
);

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Wordle Solver',
  applicationCategory: 'GameApplication',
  operatingSystem: 'Any',
  url: 'https://wordunscrambler.cc/wordle-solver',
  description: 'Free Wordle solver: enter your known letters and get every possible answer instantly.',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const faqs = [
  {
    question: 'How does the Wordle solver work?',
    answer: 'Enter the letters you know in the correct positions (pattern row), the letters that are in the word but in the wrong positions (include letters), and the letters that are not in the word at all (exclude letters). The solver filters a dictionary of 5-letter words to find matches.',
  },
  {
    question: 'Is this Wordle solver free?',
    answer: 'Yes, our Wordle solver is completely free to use with no sign-up required. Simply open the page and start entering your clues.',
  },
  {
    question: 'What are the best starting words for Wordle?',
    answer: 'The best Wordle starting words include SLATE, CRANE, TRACE, AUDIO, ADIEU, RAISE, STARE, SOARE, LARES, and RALES. These words have a good mix of common vowels and consonants to maximize information gained per guess.',
  },
  {
    question: 'Can I use it for Wordle variations?',
    answer: 'This solver is optimized for standard 5-letter Wordle. For other word lengths, try our main Word Unscrambler tool or filter by word length.',
  },
  {
    question: 'Does the solver work for the daily Wordle?',
    answer: 'Yes. The solver works with any Wordle puzzle, including the daily NYT Wordle. It uses the same word list that most Wordle clones rely on.',
  },
  {
    question: 'How accurate is the Wordle solver?',
    answer: 'Our solver uses a comprehensive dictionary of 5-letter English words. It will find every possible answer that matches your clues. If no results appear, try relaxing your constraints — a letter you thought was correct might not be.',
  },
];

---

<Layout meta={meta} fullBleed={true}>
  <div class="tool-page-skin">
    <section class="tool-hero">
      <div class="tool-hero-inner page-wrapper">
<h1 class="page-h1">Wordle Solver & Answer Finder</h1>
        <p class="page-body">
          Enter your known letters, included letters, and excluded letters to find the answer to any Wordle puzzle — instantly. Supports up to 3 wildcards (? or space).
        </p>
        <div class="page-tool-card">
          <WordleSolver client:load />
        </div>
      </div>
    </section>

    <div class="tool-content">
      <AdSense />

  <!-- What is Wordle -->
  <section class="mt-12 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-4 text-foreground">What is Wordle?</h2>
      <div class="text-[15px] text-muted-foreground leading-relaxed space-y-4">
        <p>
          <a href="https://www.nytimes.com/games/wordle/" class="text-primary hover:underline font-medium">Wordle</a> is a daily puzzle game that has taken the world by storm. Each day, players get <strong class="text-foreground">6 tries to guess a 5-letter word</strong>. After each guess, the game reveals color-coded clues:
        </p>
        <div class="grid grid-cols-3 gap-3 my-5">
          <div class="flex flex-col items-center gap-2 p-3 rounded-xl bg-[#6aaa64]/10 border border-[#6aaa64]/20">
            <div class="w-12 h-12 rounded-lg bg-[#6aaa64] flex items-center justify-center text-white font-bold text-lg">W</div>
            <span class="text-xs font-semibold text-[#6aaa64]">Green = Correct</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-xl bg-[#c9b458]/10 border border-[#c9b458]/20">
            <div class="w-12 h-12 rounded-lg bg-[#c9b458] flex items-center justify-center text-white font-bold text-lg">O</div>
            <span class="text-xs font-semibold text-[#c9b458]">Yellow = Wrong Spot</span>
          </div>
          <div class="flex flex-col items-center gap-2 p-3 rounded-xl bg-[#787c7e]/10 border border-[#787c7e]/20">
            <div class="w-12 h-12 rounded-lg bg-[#787c7e] flex items-center justify-center text-white font-bold text-lg">R</div>
            <span class="text-xs font-semibold text-[#787c7e]">Gray = Not in Word</span>
          </div>
        </div>
        <p>
          Our Wordle solver uses these same color clues to narrow down the answer from our dictionary of thousands of 5-letter words.
        </p>
      </div>
    </div>
  </section>

  <!-- Tips & Tricks -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-6 text-foreground">💡 Tips & Tricks to Win at Wordle</h2>
      <div class="space-y-5">
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">1</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Start with vowel-rich words</h3>
            <p class="text-sm text-muted-foreground">Choose first words with 3 vowels and 5 different letters. Words like <strong class="text-foreground">SLATE</strong>, <strong class="text-foreground">CRANE</strong>, and <strong class="text-foreground">ADIEU</strong> give you the most information per guess.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">2</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Learn common 5-letter words</h3>
            <p class="text-sm text-muted-foreground">Build your vocabulary with <a href="/words-by-length" class="text-primary hover:underline">common 5-letter words</a>. The more words you know, the better your starting guesses and the faster you solve puzzles.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">3</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Avoid reusing gray letters</h3>
            <p class="text-sm text-muted-foreground">Once a letter turns gray, don't guess it again. Our solver's exclude field does this automatically — just type the gray letters and they'll be filtered out.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">4</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Use a Wordle solver when stuck</h3>
            <p class="text-sm text-muted-foreground">There's no shame in using our <a href="/word-unscrambler" class="text-primary hover:underline">word unscrambler</a> or anagram solver when you're truly stuck. It's a great learning tool!</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Best Starting Words -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-4 text-foreground">🏆 Best Wordle Starting Words</h2>
      <p class="text-[15px] text-muted-foreground mb-6">
        These opening words are ranked by their ability to eliminate the most letters quickly. They maximize the information you get from your first guess.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3">
        {['SLATE', 'CRANE', 'TRACE', 'AUDIO', 'ADIEU', 'RAISE', 'STARE', 'SOARE', 'LARES', 'RALES'].map((word) => (
          <div class="flex items-center justify-center px-3 py-3 rounded-xl bg-muted border border-border font-bold text-foreground text-sm tracking-wider hover:border-primary/50 transition-colors cursor-default">
            {word}
          </div>
        ))}
      </div>
      <p class="text-xs text-muted-foreground mt-4 text-center">
        All words verified against our 5-letter word dictionary. <a href="/word-unscrambler" class="text-primary hover:underline">Try them in our unscrambler →</a>
      </p>
    </div>
  </section>

  <!-- How to Use -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl border border-border bg-card p-8 shadow-sm">
      <h2 class="text-2xl font-bold mb-6 text-foreground">How to Use the Wordle Solver</h2>
      <div class="space-y-4">
        <div class="flex gap-4">
          <div class="shrink-0 w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">1</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Pattern row — known positions</h3>
            <p class="text-sm text-muted-foreground">Type any letters you know are in the correct position. Leave boxes empty for unknown positions. This is like green tiles in Wordle.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">2</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Include letters — wrong positions</h3>
            <p class="text-sm text-muted-foreground">Type letters that appear in the word but are in the wrong position — your yellow tiles.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">3</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Exclude letters — not in word</h3>
            <p class="text-sm text-muted-foreground">Type letters that are not in the word at all — your gray tiles. They will be filtered out automatically.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-7 h-7 rounded-lg bg-primary/10 flex items-center justify-center text-primary font-bold text-sm">4</div>
          <div>
            <h3 class="font-semibold text-foreground mb-1">Find your answer</h3>
            <p class="text-sm text-muted-foreground">Click <strong class="text-foreground">Find Words</strong> to see every matching 5-letter word, sorted by Scrabble score. Results appear instantly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Play the Game CTA -->
  <section class="mt-8 max-w-3xl mx-auto">
    <div class="rounded-2xl bg-gradient-to-r from-primary/10 to-indigo-500/10 border border-primary/20 p-8 text-center">
      <h2 class="text-2xl font-bold mb-3 text-foreground">Ready to Play Wordle?</h2>
      <p class="text-[15px] text-muted-foreground mb-6">
        Skip the solver and test your skills with our free daily Wordle game — or practice with unlimited puzzles.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/play-wordle" class="btn btn-primary px-6 py-3 text-base font-semibold">🎮 Play Daily Wordle</a>
        <a href="/wordle-unlimited" class="btn btn-outline px-6 py-3 text-base">♾️ Unlimited Mode</a>
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="mt-8 mb-12 max-w-3xl mx-auto">
    <h2 class="text-xl font-bold mb-4 text-foreground">Related Tools</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {[
        { name: 'Anagram Solver', href: '/anagram-solver', icon: '📚' },
        { name: 'Scrabble Finder', href: '/scrabble', icon: '🎲' },
        { name: 'Word Unscrambler', href: '/word-unscrambler', icon: '🔤' },
        { name: 'Words by Length', href: '/words-by-length', icon: '📏' },
      ].map((tool) => (
        <a href={tool.href} class="flex items-center gap-2 p-3 rounded-xl border border-border bg-card hover:border-primary/50 hover:shadow-sm transition-all group">
          <span class="text-xl">{tool.icon}</span>
          <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{tool.name}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- FAQ -->
  <section class="mt-8 max-w-3xl mx-auto" id="faq">
    <h2 class="page-h2">Frequently Asked Questions</h2>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="faq-details">
          <summary class="faq-summary">
            <span class="font-semibold text-foreground text-[15px]">{faq.question}</span>
            <span class="faq-icon">+</span>
          </summary>
          <div class="faq-body">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
    <InternalLinks />
  </section>

      <div class="mt-12"></div>

      <SchemaOrg data={appSchema} />
      <SeoSchemaBlocks faqs={faqs} />
    </div>
  </div>
</Layout>
