---
import BaseHead from '@/components/BaseHead.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import AdSense from '@/components/AdSense.astro';
import { getMeta } from '@/lib/meta';
import type { PageMeta } from '@/lib/meta';
import '@/styles/global.css';

interface Props {
  meta: PageMeta;
  title?: string;
  /** Use wider main (max-w-7xl) for two-column pages like N-letter-words */
  wide?: boolean;
  /** Game layout - centered content with no sidebar constraints */
  game?: boolean;
  /** Full-width main (no container); page supplies its own layout e.g. hero bleed */
  fullBleed?: boolean;
}
const { meta, wide = false, game = false, fullBleed = false } = Astro.props;
const mainClass = fullBleed
  ? 'page-main w-full max-w-none px-0 py-0 mx-0'
  : game 
    ? 'page-main container mx-auto px-4 py-6 max-w-lg' 
    : wide 
      ? 'page-main container mx-auto px-4 py-8 max-w-7xl' 
      : 'page-main container mx-auto px-4 py-8 max-w-4xl';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={meta.title} description={meta.description} canonical={meta.canonical} noindex={meta.noindex} />
    <script is:inline>
      (function(){var k='word-unscrambler-theme';var s=typeof localStorage!=='undefined'?localStorage.getItem(k):null;var d=typeof window!=='undefined'&&window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='dark'||(!s&&d))document.documentElement.classList.add('dark');})();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <SiteHeader />
    <main id="main-content" class={mainClass} role="main">
      <slot />
    </main>
    <AdSense />
    <SiteFooter />
    <slot name="footer" />
    <script>
      // Stagger section entrance animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.querySelectorAll('.stagger-item').forEach((el) => el.classList.add('visible'));
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.stagger-section').forEach((s) => observer.observe(s));

      // Tool pages: auto-build left sidebar + right article layout
      const toolWrappers = document.querySelectorAll('.tool-page-skin .tool-content > .page-wrapper');
      toolWrappers.forEach((wrapper) => {
        if (!(wrapper instanceof HTMLElement)) return;
        if (wrapper.querySelector('.tool-main-with-sidebar')) return;

        const shell = document.createElement('div');
        shell.className = 'tool-main-with-sidebar';

        const sidebar = document.createElement('aside');
        sidebar.className = 'tool-main-sidebar';
        sidebar.innerHTML = `
          <section class="tool-side-card" aria-label="Games">
            <h3 class="tool-side-title">Games</h3>
            <ul class="tool-side-links">
              <li><a href="/play-wordle">Wordle Daily Challenge</a></li>
              <li><a href="/wordle-unlimited">Wordle Unlimited</a></li>
              <li><a href="/crossword-solver">Mini Crossword</a></li>
            </ul>
          </section>
          <section class="tool-side-card" aria-label="Word Finder">
            <h3 class="tool-side-title">Word Finder</h3>
            <ul class="tool-side-links">
              <li><a href="/nyt-crossplay-solver">NYT Crossplay Solver</a></li>
              <li><a href="/word-finder">Word Finder</a></li>
              <li><a href="/wordle-solver">Wordle Solver</a></li>
              <li><a href="/crossword-solver">Crossword Solver</a></li>
              <li><a href="/word-unscrambler">Word Unscrambler</a></li>
              <li><a href="/word-scramble">Word Scramble</a></li>
            </ul>
          </section>
        `;

        const article = document.createElement('div');
        article.className = 'tool-main-article';
        while (wrapper.firstChild) {
          article.appendChild(wrapper.firstChild);
        }

        shell.appendChild(sidebar);
        shell.appendChild(article);
        wrapper.appendChild(shell);
      });
    </script>
  </body>
</html>
